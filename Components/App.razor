<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    
    @using Microsoft.AspNetCore.Hosting
    @inject IWebHostEnvironment Env
    
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["BettingApp.styles.css"]" />
    <ImportMap />
    
    @if (Env.IsDevelopment())
    {
        <link rel="icon" type="image/png" href="favicon.png" />
    }
    else
    {
        <link rel="icon" type="image/png" href="favicon-prod.png" />
    }
    
    <HeadOutlet />
</head>

<body>
    <CascadingAuthenticationState>
        <ErrorBoundary>
            <Routes />
        </ErrorBoundary>
    </CascadingAuthenticationState>
    
    <script>
        window.getBrowserTimeZoneOffset = function() {
            return new Date().getTimezoneOffset();
        };
    </script>
    
    <script src="@Assets["lib/bootstrap/dist/js/bootstrap.bundle.min.js"]"></script>
    <script src="js/discordMarkdown.js"></script>
    
    @* --- MOBILE OPTIMIZED RECONNECTION LOGIC --- *@
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        // 1. Tell Blazor to retry faster rather than waiting 10-15 seconds between attempts
        // Give it up to 30 seconds to try reconnecting before officially failing
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 30,
                    retryIntervalMilliseconds: 1000
                }
            }
        });

        // 2. Safely monitor for the reconnect modal without queueing infinite loops
        let reconnectTimer = null;
        const observer = new MutationObserver(() => {
            const modal = document.getElementById('components-reconnect-modal');
            if (modal) {
                // If Blazor officially gave up or the circuit was rejected, reload immediately
                if (modal.classList.contains('components-reconnect-failed') || 
                    modal.classList.contains('components-reconnect-rejected')) {
                    console.log("Reconnection failed/rejected. Reloading to recover.");
                    window.location.reload();
                    return;
                }
                
                // If it's still trying to reconnect, give it plenty of time to succeed 
                // so the user doesn't lose their state on a slow connection.
                if (modal.classList.contains('components-reconnect-show')) {
                    if (!reconnectTimer) {
                        reconnectTimer = setTimeout(() => {
                            console.log("Stuck rejoining for 35 seconds. Reloading to recover.");
                            window.location.reload();
                        }, 35000);
                    }
                } else {
                    // Modal is hidden (reconnected successfully!)
                    if (reconnectTimer) {
                        clearTimeout(reconnectTimer);
                        reconnectTimer = null;
                    }
                }
            }
        });
        observer.observe(document.body, { childList: true, subtree: true, attributes: true });
    </script>
</body>

</html>