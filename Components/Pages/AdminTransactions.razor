@page "/admin/transactions"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@using BettingApp.Hubs
@using BettingApp.Data
@using BettingApp.Services
@using Microsoft.EntityFrameworkCore
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IHubContext<BetHub> HubContext
@inject IJSRuntime JSRuntime
@inject DiscordNotificationService DiscordService
@attribute [Authorize]
@rendermode InteractiveServer

<h3>Manage Transactions</h3>

@if (successMessage != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-bell-fill me-2"></i> @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (errorMessage != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
        <button type="button" class="btn-close" @onclick="() => errorMessage = null"></button>
    </div>
}

<div class="card border-warning mb-4">
    <div class="card-header bg-warning text-dark">
        <strong>Pending Withdraw Requests</strong>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date (Local)</th>
                        <th>Date (Norway)</th>
                        <th>Discord Username</th>
                        <th>Last Name</th>
                        <th>Payment Method</th>
                        <th>Amount</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pendingWithdrawals.Count == 0)
                    {
                        <tr><td colspan="7" class="text-center text-muted p-3">No pending withdrawals.</td></tr>
                    }
                    @foreach (var w in pendingWithdrawals)
                    {
                        <tr>
                            <td>@ToUserLocal(w.Date).ToString("g")</td>
                            <td>@TimeHelpers.GetNorwayTime(w.Date).ToString("g")</td>
                            <td>@(userLookup.TryGetValue(w.UserId, out var u) && !string.IsNullOrEmpty(u.DiscordName) ? u.DiscordName : w.UserName)</td>
                            <td>@(userLookup.TryGetValue(w.UserId, out var u2) ? u2.LastName : "")</td>
                            <td>
                                @w.Platform
                                @if(!string.IsNullOrEmpty(w.PaymentDetails)) {
                                    <br/><small class="text-muted">@w.PaymentDetails</small>
                                }
                            </td>
                            <td><strong>@w.AmountNOK.ToString("N0") kr</strong></td>
                            <td>
                                <button class="btn btn-success btn-sm me-2" @onclick="() => ConfirmWithdraw(w)">
                                    Confirm Payout
                                </button>
                                <button class="btn btn-danger btn-sm" @onclick="() => RejectWithdraw(w)">
                                    Reject
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-12 mb-4">
        <div class="card">
             <div class="card-header bg-primary text-white">Add Transaction (Manual)</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3 position-relative">
                        <label>Target User (Search Discord)</label>
                        <input type="text" class="form-control" 
                               placeholder="Start typing Discord username..." 
                               @bind="searchTerm" 
                               @oninput="SearchUsers" />
                        
                        @if (searchResults.Any())
                        {
                            <ul class="list-group position-absolute w-100 shadow" style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                                @foreach (var user in searchResults)
                                {
                                     <li class="list-group-item list-group-item-action" 
                                        style="cursor: pointer;" 
                                        @onclick="() => SelectUser(user)">
                                        <strong>@(!string.IsNullOrEmpty(user.DiscordUsername) ? user.DiscordUsername : user.UserName)</strong> 
                                        <small class="text-muted ms-1">(@user.Balance.ToString("N0") kr)</small>
                                     </li>
                                }
                            </ul>
                        }

                        @if (selectedUser != null)
                        {
                            <div class="mt-2 p-2 bg-light border rounded small">
                                <div class="d-flex justify-content-between">
                                    <span>Balance:</span>
                                    <span class="@(selectedUser.Balance >= 0 ? "text-success" : "text-danger") fw-bold">
                                        @selectedUser.Balance.ToString("N0") kr
                                    </span>
                                </div>
                                <div class="text-success">
                                    <small>Selected: <strong>@(!string.IsNullOrEmpty(selectedUser.DiscordUsername) ? selectedUser.DiscordUsername : selectedUser.UserName)</strong></small>
                                    <button class="btn btn-link btn-sm p-0 ms-2 text-danger" @onclick="ClearSelection">(x)</button>
                                </div>
                            </div>
                         }
                    </div>

                    <div class="col-md-4 mb-3">
                        <label>Type</label>
                        <div class="btn-group w-100" role="group">
                            <input type="radio" class="btn-check" name="btnradio" id="typeDeposit" autocomplete="off" 
                                   checked="@(newTrans.Type == "Deposit")" @onclick="@(() => ChangeType("Deposit"))">
                            <label class="btn btn-outline-success" for="typeDeposit">Deposit</label>

                            <input type="radio" class="btn-check" name="btnradio" id="typeWithdraw" autocomplete="off" 
                                   checked="@(newTrans.Type == "Withdrawal")" @onclick="@(() => ChangeType("Withdrawal"))">
                            <label class="btn btn-outline-warning" for="typeWithdraw">Withdraw</label>
                            
                             <input type="radio" class="btn-check" name="btnradio" id="typeFreeBet" autocomplete="off" 
                                   checked="@(newTrans.Type == "Free Bet")" @onclick="@(() => ChangeType("Free Bet"))">
                            <label class="btn btn-outline-info" for="typeFreeBet">Free Bet</label>
                        </div>
                    </div>

                    @if (newTrans.Type == "Free Bet")
                    {
                         <div class="col-md-3 mb-3">
                            <label>Note</label>
                            <input type="text" class="form-control" placeholder="e.g. Promotional Free Bet" @bind="newTrans.PaymentDetails" />
                        </div>
                        <div class="col-md-2 mb-3">
                            <label>Amount (NOK)</label>
                            <input type="number" class="form-control" @bind="adminAddAmount" />
                        </div>
                    }
                    else
                    {
                         <div class="col-md-3 mb-3">
                            <label>Payment Method</label>
                            <select class="form-select" @bind="newTrans.Platform">
                                <option value="PayPal">PayPal</option>
                                <option value="Vipps">Vipps</option>
                                <option value="Revolut">Revolut</option>
                                <option value="Crypto">Crypto</option>
                            </select>
                        </div>
                        <div class="col-md-2 mb-3">
                             <label>Amount (NOK)</label>
                            <input type="number" class="form-control" @bind="adminAddAmount" />
                        </div>
                        <div class="col-md-12 mb-3">
                            <label>
                                @if (newTrans.Platform == "PayPal") { <text>Email/Mobile</text> }
                                else if (newTrans.Platform == "Vipps") { <text>Phone Number</text> }
                                else if (newTrans.Platform == "Revolut") { <text>Revtag/Username</text> }
                                else if (newTrans.Platform == "Crypto") { <text>Wallet Address</text> }
                                else { <text>Payment Details</text> }
                            </label>
                            <input type="text" class="form-control" @bind="newTrans.PaymentDetails" />
                         </div>
                    }

                    <div class="col-md-12 mb-3">
                        <button class="btn btn-primary w-100" @onclick="AddTransaction" disabled="@(selectedUser == null)">Add Transaction</button>
                     </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">
    <h4 class="mb-0">Transaction History</h4>
    
    <div class="position-relative" style="min-width: 250px;">
        <div class="input-group input-group-sm">
            <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" 
                   placeholder="Filter by user..." 
                   @bind="filterSearchTerm" 
                   @oninput="SearchFilterUsers" />
        </div>
        
        @if (filterSearchResults.Any())
        {
            <ul class="list-group position-absolute w-100 shadow mt-1" style="z-index: 1000; max-height: 200px; overflow-y: auto;">
                @foreach (var user in filterSearchResults)
                {
                    <li class="list-group-item list-group-item-action py-1" 
                        style="cursor: pointer;" 
                        @onclick="() => SelectFilterUser(user)">
                        <strong>@(!string.IsNullOrEmpty(user.DiscordUsername) ? user.DiscordUsername : user.UserName)</strong>
                    </li>
                }
            </ul>
        }
         @if (filterSelectedUser != null)
        {
            <div class="mt-1 small text-success d-flex justify-content-between align-items-center bg-light border rounded px-2 py-1">
                <span class="text-truncate">Filtering: <strong>@(!string.IsNullOrEmpty(filterSelectedUser.DiscordUsername) ? filterSelectedUser.DiscordUsername : filterSelectedUser.UserName)</strong></span>
                <button class="btn btn-link btn-sm p-0 text-danger text-decoration-none" @onclick="ClearFilterSelection"><i class="bi bi-x-circle-fill"></i> clear</button>
             </div>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-striped table-hover align-middle text-nowrap">
        <thead class="table-dark">
            <tr>
                <th>Last Updated (Local)</th>
                <th>Last Updated (Norway)</th>
                <th>Discord Username</th>
                <th>Last Name</th>
                <th>Type</th>
                <th>Payment Method</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
         <tbody>
            @foreach (var t in allTransactions)
            {
                <tr>
                    <td>@ToUserLocal(t.UpdatedAt).ToString("g")</td>
                    <td>@TimeHelpers.GetNorwayTime(t.UpdatedAt).ToString("g")</td>
                    <td>@(userLookup.TryGetValue(t.UserId, out var u) && !string.IsNullOrEmpty(u.DiscordName) ? u.DiscordName : t.UserName)</td>
                    <td>@(userLookup.TryGetValue(t.UserId, out var u2) ? u2.LastName : "")</td>
                    <td>
                         @if (t.Type == "Deposit")
                        {
                            <span class="badge bg-success">Deposit</span>
                        }
                        else if (t.Type == "Free Bet")
                        {
                            <span class="badge bg-info text-dark">Free Bet</span>
                        }
                         else
                        {
                            <span class="badge bg-warning text-dark">@((t.Type == "Withdrawal" ? "Withdraw" : t.Type))</span>
                        }
                    </td>
                    <td>
                        @t.Platform
                        @if(!string.IsNullOrEmpty(t.PaymentDetails)) {
                             <br/><small class="text-muted">@t.PaymentDetails</small>
                        }
                    </td>
                    <td>@t.AmountNOK.ToString("N0") kr</td>
                     <td>
                        @if (t.Status == "Completed" || t.Status == "Won" || t.Status == "Approved")
                        {
                            <span class="badge bg-success">@t.Status</span>
                        }
                        else if (t.Status == "Pending")
                        {
                            <span class="badge bg-warning text-dark">@t.Status</span>
                        }
                        else if (t.Status == "Rejected" || t.Status == "Lost" || t.Status == "Cancelled")
                        {
                            <span class="badge bg-danger">@t.Status</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@t.Status</span>
                        }
                    </td>
                    <td>
                         @if (t.Status != "Cancelled" && t.Status != "Rejected" && t.Status != "Lost")
                         {
                             <button class="btn btn-danger btn-sm py-0" @onclick="() => CancelTransaction(t)" title="Cancel Transaction">
                                 <i class="bi bi-x-circle"></i> Cancel
                             </button>
                         }
                    </td>
                </tr>
            }
            @if (allTransactions.Count == 0)
            {
                <tr><td colspan="9" class="text-muted text-center py-3">No transactions found for this period/user.</td></tr>
            }
        </tbody>
    </table>
    
    <div class="d-flex justify-content-between align-items-center mt-2 mb-4">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevPage" disabled="@(currentPage <= 1)">
            <i class="bi bi-arrow-left"></i> Previous
        </button>
        <span class="text-muted">Page @currentPage</span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="NextPage" disabled="@(!hasMoreTransactions)">
             Next <i class="bi bi-arrow-right"></i>
        </button>
    </div>
</div>

@code {
    private List<Transaction> allTransactions = new();
    private List<Transaction> pendingWithdrawals = new();
    
    private Dictionary<string, (string DiscordName, string LastName)> userLookup = new();
    private Transaction newTrans = new() { Type = "Deposit", Platform = "PayPal", Date = DateTime.UtcNow, Status = "Completed" };
    private int? adminAddAmount; 
    
    private string searchTerm = "";
    private List<ApplicationUser> searchResults = new();
    private ApplicationUser? selectedUser;

    private string filterSearchTerm = "";
    private List<ApplicationUser> filterSearchResults = new();
    private ApplicationUser? filterSelectedUser;
    
    private string? successMessage;
    private string? errorMessage;
    private string? currentAdminName;
    private HubConnection? hubConnection;
    
    private int currentPage = 1;
    private const int PageSize = 20;
    private bool hasMoreTransactions = false;

    private int TimezoneOffset { get; set; }

    private DateTime ToUserLocal(DateTime utcDate)
    {
        if (utcDate == DateTime.MinValue || utcDate == DateTime.MaxValue) return utcDate;
        return utcDate.AddMinutes(-TimezoneOffset);
    }
    
    private async Task PopulateUserLookup(IEnumerable<string> userIds)
    {
        var missingIds = userIds.Except(userLookup.Keys).Distinct().ToList();
        if (missingIds.Any())
        {
            using var context = DbFactory.CreateDbContext();
            var users = await context.Users.Where(u => missingIds.Contains(u.Id)).Select(u => new { u.Id, u.DiscordUsername, u.LastName }).ToListAsync();
            foreach(var u in users) {
                userLookup[u.Id] = (u.DiscordUsername ?? "", u.LastName ?? "");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentAdminName = user.Identity?.Name;

        using var context = DbFactory.CreateDbContext();
        var userName = user.Identity?.Name;
        ApplicationUser? dbUser = null;
        if (!string.IsNullOrEmpty(userName))
        {
            dbUser = await context.Users.FirstOrDefaultAsync(u => u.UserName == userName);
        }

        if (dbUser == null || !dbUser.IsAdmin)
        {
            Nav.NavigateTo("/");
            return;
        }

        await LoadTransactions(context);
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                TimezoneOffset = await JSRuntime.InvokeAsync<int>("getBrowserTimeZoneOffset");
                StateHasChanged();
            } catch { }
            
            try { await SetupSignalR(); } catch { }
        }
    }

    private void ChangeType(string type)
    {
        newTrans.Type = type;
        if (type == "Free Bet")
        {
            newTrans.Platform = "Free Bet";
            newTrans.PaymentDetails = string.Empty;
        }
        else
        {
            newTrans.Platform = "PayPal";
            newTrans.PaymentDetails = string.Empty;
        }
    }

    private async Task SearchUsers(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? "";
        
        if (string.IsNullOrWhiteSpace(searchTerm) || searchTerm.Length < 2)
        {
            searchResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        searchResults = await context.Users
            .Where(u => u.DiscordUsername != null && u.DiscordUsername.Contains(searchTerm) || (u.UserName != null && u.UserName.Contains(searchTerm)))
            .OrderBy(u => u.DiscordUsername) 
            .Take(5)
            .AsNoTracking()
            .ToListAsync();
    }

    private void SelectUser(ApplicationUser user)
    {
        selectedUser = user;
        searchTerm = !string.IsNullOrEmpty(user.DiscordUsername) ? user.DiscordUsername : (user.UserName ?? "");
        searchResults.Clear();
        
        newTrans.UserId = selectedUser.Id;
        newTrans.UserName = selectedUser.UserName ?? "Unknown";
        errorMessage = null;
    }

    private void ClearSelection()
    {
        selectedUser = null;
        searchTerm = "";
        searchResults.Clear();
        newTrans.UserId = "";
    }

    private async Task SearchFilterUsers(ChangeEventArgs e)
    {
        filterSearchTerm = e.Value?.ToString() ?? "";
        
        if (string.IsNullOrWhiteSpace(filterSearchTerm) || filterSearchTerm.Length < 2)
        {
            filterSearchResults.Clear();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        filterSearchResults = await context.Users
            .Where(u => u.DiscordUsername != null && u.DiscordUsername.Contains(filterSearchTerm) || (u.UserName != null && u.UserName.Contains(filterSearchTerm)))
            .OrderBy(u => u.DiscordUsername) 
            .Take(5)
            .AsNoTracking()
            .ToListAsync();
    }

    private async Task SelectFilterUser(ApplicationUser user)
    {
        filterSelectedUser = user;
        filterSearchTerm = "";
        filterSearchResults.Clear();
        currentPage = 1; 
        
        using var context = DbFactory.CreateDbContext();
        await LoadTransactions(context);
    }

    private async Task ClearFilterSelection()
    {
        filterSelectedUser = null;
        filterSearchTerm = "";
        filterSearchResults.Clear();
        currentPage = 1; 
        
        using var context = DbFactory.CreateDbContext();
        await LoadTransactions(context);
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/bethub")).Build();
        hubConnection.On<string>("ReceiveUpdate", async (message) =>
        {
            using var context = DbFactory.CreateDbContext();
            await LoadTransactions(context);
            await InvokeAsync(StateHasChanged);
        });
        hubConnection.On<string>("ReceiveAdminNotification", async (message) =>
        {
            using var context = DbFactory.CreateDbContext();
            await LoadTransactions(context);
            await InvokeAsync(StateHasChanged);
        });
        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("JoinAdminGroup");
    }

    private async Task LoadTransactions(ApplicationDbContext context)
    {
        var query = context.Transactions.AsQueryable();
        if (filterSelectedUser != null)
        {
            query = query.Where(t => t.UserId == filterSelectedUser.Id);
        }

        allTransactions = await query
            .OrderByDescending(t => t.UpdatedAt)
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .AsNoTracking()
            .ToListAsync();
        var total = await query.CountAsync();
        hasMoreTransactions = total > (currentPage * PageSize);
        pendingWithdrawals = await context.Transactions
            .Where(t => t.Type == "Withdrawal" && t.Status == "Pending")
            .OrderBy(t => t.Date)
            .AsNoTracking()
            .ToListAsync();
        var userIds = allTransactions.Select(t => t.UserId).Concat(pendingWithdrawals.Select(t => t.UserId)).Distinct();
        await PopulateUserLookup(userIds);
    }
    
    private async Task NextPage() { currentPage++; using var c = DbFactory.CreateDbContext();
    await LoadTransactions(c); }
    private async Task PrevPage() { if(currentPage > 1) { currentPage--;
    using var c = DbFactory.CreateDbContext(); await LoadTransactions(c); } }

    private async Task ConfirmWithdraw(Transaction t)
    {
        successMessage = null;
        errorMessage = null;
        var displayUser = userLookup.TryGetValue(t.UserId, out var u) && !string.IsNullOrEmpty(u.DiscordName) ? u.DiscordName : t.UserName;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Confirm payout of {t.AmountNOK} kr to {displayUser}?");
        if (!confirmed) return;

        using var context = DbFactory.CreateDbContext();
        
        var user = await context.Users.FindAsync(t.UserId);
        var dbTrans = await context.Transactions.FindAsync(t.Id);
        if (dbTrans != null)
        {
            dbTrans.Status = "Completed";
            dbTrans.UpdatedAt = DateTime.UtcNow;
            context.AuditLogs.Add(new AuditLog { AdminUserName = currentAdminName ?? "Unknown", Action = "Confirmed Withdrawal", TargetUserName = t.UserName, Details = $"Amount: {t.AmountNOK}, Platform: {t.Platform}" });
            await context.SaveChangesAsync();
            await HubContext.Clients.Group(t.UserId).SendAsync("ReceiveUpdate", "Withdrawal confirmed");
            
            if (user != null && !string.IsNullOrEmpty(user.DiscordUserId))
            {
                await DiscordService.NotifyUserWithdrawalAsync(user.DiscordUserId, t, "Completed");
            }

            successMessage = "Withdrawal confirmed.";
            await LoadTransactions(context);
        }
    }

    private async Task RejectWithdraw(Transaction t)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Reject this withdrawal request?");
        if (!confirmed) return;

        using var context = DbFactory.CreateDbContext();
        var dbTrans = await context.Transactions.FindAsync(t.Id);
        var user = await context.Users.FindAsync(t.UserId);
        if (dbTrans != null && user != null)
        {
            dbTrans.Status = "Rejected";
            dbTrans.UpdatedAt = DateTime.UtcNow;
            
            user.Balance += t.AmountNOK;
            context.AuditLogs.Add(new AuditLog { AdminUserName = currentAdminName ?? "Unknown", Action = "Rejected Withdrawal", TargetUserName = t.UserName, Details = $"Amount: {t.AmountNOK}, ID: {t.Id}" });
            await context.SaveChangesAsync();
            
            await HubContext.Clients.Group(t.UserId).SendAsync("ReceiveUpdate", "Withdrawal rejected");
            if (!string.IsNullOrEmpty(user.DiscordUserId))
            {
                await DiscordService.NotifyUserWithdrawalAsync(user.DiscordUserId, t, "Rejected");
            }
            successMessage = "Withdrawal rejected.";
            await LoadTransactions(context);
        }
    }

    private async Task CancelTransaction(Transaction t)
    {
        var displayUser = userLookup.TryGetValue(t.UserId, out var u) && !string.IsNullOrEmpty(u.DiscordName) ?
        u.DiscordName : t.UserName;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", 
            $"Are you sure you want to CANCEL this transaction?\nType: {t.Type}\nAmount: {t.AmountNOK} kr\nUser: {displayUser}\n\nThis will reverse the balance.");
        if (!confirmed) return;

        using var context = DbFactory.CreateDbContext();
        var dbTrans = await context.Transactions.FindAsync(t.Id);
        var user = await context.Users.FindAsync(t.UserId);
        if (dbTrans != null && user != null)
        {
            if (dbTrans.Status == "Cancelled" || dbTrans.Status == "Rejected")
            {
                errorMessage = "Transaction is already cancelled or rejected.";
                return;
            }

            if (dbTrans.Type == "Deposit")
            {
                user.Balance -= dbTrans.AmountNOK;
            }
            else if (dbTrans.Type == "Free Bet")
            {
                user.FreeBetBalance -= dbTrans.AmountNOK;
            }
            else if (dbTrans.Type == "Withdrawal")
            {
                user.Balance += dbTrans.AmountNOK;
            }

            dbTrans.Status = "Cancelled";
            dbTrans.UpdatedAt = DateTime.UtcNow;

            context.AuditLogs.Add(new AuditLog 
            { 
                AdminUserName = currentAdminName ?? "Unknown", 
                Action = "Cancelled Transaction", 
                TargetUserName = user.UserName ?? "Unknown", 
                Details = $"Cancelled {dbTrans.Type} of {dbTrans.AmountNOK}. ID: {dbTrans.Id}" 
            });
            await context.SaveChangesAsync();

            await HubContext.Clients.Group(t.UserId).SendAsync("ReceiveUpdate", $"Transaction #{t.Id} was cancelled.");
            await HubContext.Clients.Group("Admins").SendAsync("ReceiveAdminNotification", "Transaction Cancelled");

            successMessage = "Transaction cancelled and balance reversed successfully.";
            await LoadTransactions(context);
        }
        else
        {
            errorMessage = "Transaction or User not found.";
        }
    }

    private async Task AddTransaction()
    {
        successMessage = null;
        errorMessage = null;
        
        if (string.IsNullOrEmpty(newTrans.UserId) || !adminAddAmount.HasValue || adminAddAmount.Value <= 0 || string.IsNullOrEmpty(newTrans.Platform))
        {
            errorMessage = "Please fill in all fields (User, valid Amount, and Platform).";
            return;
        }
        
        if (newTrans.Type != "Free Bet" && string.IsNullOrWhiteSpace(newTrans.PaymentDetails))
        {
            errorMessage = "Please provide payment details/address.";
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var user = await context.Users.FindAsync(newTrans.UserId);
        if (user == null) { errorMessage = "User not found"; return;
        }

        if (newTrans.Type == "Withdrawal")
        {
            if (user.Balance < adminAddAmount.Value)
            {
                errorMessage = $"Insufficient funds. Balance: {user.Balance:N0}";
                return;
            }
            user.Balance -= adminAddAmount.Value;
        }
        else if (newTrans.Type == "Free Bet")
        {
            user.FreeBetBalance += adminAddAmount.Value;
        }
        else 
        {
            user.Balance += adminAddAmount.Value;
        }

        newTrans.AmountNOK = adminAddAmount.Value;
        newTrans.UserName = user.UserName ?? "Unknown";
        newTrans.Date = DateTime.UtcNow;
        newTrans.UpdatedAt = DateTime.UtcNow;
        newTrans.Status = "Completed"; 

        context.Transactions.Add(newTrans);
        context.AuditLogs.Add(new AuditLog { AdminUserName = currentAdminName ?? "Unknown", Action = $"Added {newTrans.Type}", TargetUserName = newTrans.UserName, Details = $"Amount: {newTrans.AmountNOK}, Platform: {newTrans.Platform}" });
        await context.SaveChangesAsync();
        
        await HubContext.Clients.Group(newTrans.UserId).SendAsync("ReceiveUpdate", $"New transaction: {newTrans.Type}");
        await HubContext.Clients.Group("Admins").SendAsync("ReceiveAdminNotification", "Update");
        
        if (!string.IsNullOrEmpty(user.DiscordUserId))
        {
            if (newTrans.Type == "Withdrawal")
            {
                await DiscordService.NotifyUserWithdrawalAsync(user.DiscordUserId, newTrans, "Completed");
            }
            else if (newTrans.Type == "Free Bet")
            {
                await DiscordService.NotifyUserFreeBetAsync(user.DiscordUserId, newTrans.AmountNOK, newTrans.PaymentDetails);
            }
        }
        
        successMessage = "Transaction added successfully!";
        var type = newTrans.Type; 
        newTrans = new Transaction { Type = type, Platform = type == "Free Bet" ?
        "Free Bet" : "PayPal", Date = DateTime.UtcNow, Status = "Completed" };
        adminAddAmount = null;
        
        ClearSelection();
        await LoadTransactions(context);
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) { await hubConnection.DisposeAsync();
        }
    }
}