            </div>
        </div>
    </div>
</div>

@code {
    private List<Bet> pendingBets = new();
    private List<Bet> approvedBets = new();
    private List<Bet> completedBets = new();
    private Dictionary<string, (string DiscordName, string LastName)> userLookup = new();
    private int pendingPage = 1;
    private int approvedPage = 1;
    private int completedPage = 1;
    private int pageSize = 25;
    
    private string completedStatusFilter = "All";
    private string completedSearchBetId = "";
    
    private async Task OnCompletedStatusFilterChanged(ChangeEventArgs e)
    {
        completedStatusFilter = e.Value?.ToString() ?? "All";
        completedPage = 1;
        await LoadCompletedBets();
    }

    private async Task OnCompletedSearchChanged()
    {
        completedPage = 1;
        await LoadCompletedBets();
    }

    private async Task ClearCompletedSearch()
    {
        completedSearchBetId = "";
        completedPage = 1;
        await LoadCompletedBets();
    }
    private bool hasMoreCompletedBets = false;
    private bool hasMoreApprovedBets = false;
    private bool hasMorePendingBets = false;
    private int totalCompletedBets = 0;
    private int totalPendingBets = 0;
    private int totalApprovedBets = 0;

    private string? successMessage;
    private string? errorMessage;
    private HubConnection? hubConnection;
    private string? currentAdminName;
    private Bet? reviewingBetModel;
    private Bet? originalBetModel;
    private string? reviewErrorMessage;
    private decimal currentReviewUserFreeBalance = 0;
    


    private string? modalSuccessMessage;
    private ElementReference reviewModalRef;
    private bool shouldFocusReviewModal = false;
    
    private List<Bet> currentReviewList = new();
    private int currentReviewIndex = -1;
    private string reviewContext = "";
    
    private double touchStartX = 0;
    private double touchEndX = 0;
    [SupplyParameterFromQuery]
    public int? ReviewBetId { get; set; }

    private int TimezoneOffset { get; set; }

    private DateTime ToUserLocal(DateTime utcDate)
    {
        if (utcDate == DateTime.MinValue || utcDate == DateTime.MaxValue) return utcDate;
        return utcDate.AddMinutes(-TimezoneOffset);
    }

    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Approved" => "bg-success",
            "Won" => "bg-success",
            "Pending" => "bg-warning text-dark",
            "Lost" => "bg-danger",
            "Rejected" => "bg-danger",
            "Cancelled" => "bg-dark",
            _ => "bg-secondary"
        };
    }

    private decimal GetNetProfit(Bet bet)
    {
        // Admin profit logic:
        // For normal bets, profit is (Stake - Payout).
        // For free bets, profit is (-Payout) because the stake was already "paid for" upon granting.
        // Stake portions that matter: Real portion = (Total - Free).
        
        decimal realStakePortion = (decimal)(bet.AmountNOK ?? 0) - bet.FreeBetAmount;

        if (bet.Status == "Lost") return realStakePortion;
        if (bet.Status == "Won") return realStakePortion - bet.PotentialPayout;
        return 0; // Void/Rejected/Cancelled don't affect profit
    }

    private async Task PopulateUserLookup(IEnumerable<string> userIds)
    {
        var missingIds = userIds.Except(userLookup.Keys).Distinct().ToList();
        if (missingIds.Any())
        {
            using var context = DbFactory.CreateDbContext();
            var users = await context.Users.Where(u => missingIds.Contains(u.Id)).Select(u => new { u.Id, u.DiscordUsername, u.LastName }).ToListAsync();
            foreach(var u in users) {
                userLookup[u.Id] = (u.DiscordUsername ?? "", u.LastName ?? "");
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentAdminName = user.Identity?.Name;

        using var context = DbFactory.CreateDbContext();
        var currentUserName = user.Identity?.Name;
        var dbUser = currentUserName != null ? await context.Users.FirstOrDefaultAsync(u => u.UserName == currentUserName) : null;
        if (dbUser == null || !dbUser.IsAdmin)
        {
            Nav.NavigateTo("/");
            return;
        }

        await LoadPendingBets();
        await LoadApprovedBets();
        await LoadCompletedBets();
        if (ReviewBetId.HasValue)
        {
            var targetBet = pendingBets.FirstOrDefault(b => b.Id == ReviewBetId.Value);
            if (targetBet == null) targetBet = approvedBets.FirstOrDefault(b => b.Id == ReviewBetId.Value);

            if (targetBet != null) StartReview(targetBet);
            else 
            {
                var exists = await context.Bets.AnyAsync(b => b.Id == ReviewBetId.Value);
                if (exists) errorMessage = $"Bet #{ReviewBetId.Value} is already reviewed.";
                else errorMessage = $"Bet #{ReviewBetId.Value} not found.";
            }
        }
    }
    
    private async Task LoadPendingBets()
    {
        using var context = DbFactory.CreateDbContext();
        totalPendingBets = await context.Bets.CountAsync(b => b.Status == "Pending");
        pendingBets = await context.Bets.Where(b => b.Status == "Pending")
            .OrderByDescending(b => b.UpdatedAt)
            .Skip((pendingPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
        hasMorePendingBets = totalPendingBets > (pendingPage * pageSize);
        await PopulateUserLookup(pendingBets.Select(b => b.UserId));
    }
    
    private async Task LoadApprovedBets()
    {
        using var context = DbFactory.CreateDbContext();
        totalApprovedBets = await context.Bets.CountAsync(b => b.Status == "Approved");
        approvedBets = await context.Bets.Where(b => b.Status == "Approved")
            .OrderByDescending(b => b.UpdatedAt)
            .Skip((approvedPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
        hasMoreApprovedBets = totalApprovedBets > (approvedPage * pageSize);
        await PopulateUserLookup(approvedBets.Select(b => b.UserId));
    }
    
    private async Task NextPendingPage() { pendingPage++; await LoadPendingBets(); }
    private async Task PrevPendingPage() { if (pendingPage > 1) { pendingPage--; await LoadPendingBets(); } }
    
    private async Task NextApprovedPage() { approvedPage++; await LoadApprovedBets(); }
    private async Task PrevApprovedPage() { if (approvedPage > 1) { approvedPage--; await LoadApprovedBets(); } }

    private async Task LoadCompletedBets()
    {
        using var context = DbFactory.CreateDbContext();
        var completedStatuses = new[] { "Won", "Lost", "Void", "Rejected", "Cancelled" };
        
        var query = context.Bets.AsQueryable();
        if (!string.IsNullOrWhiteSpace(completedSearchBetId))
        {
            if (int.TryParse(completedSearchBetId.Trim(), out int searchId))
            {
                query = query.Where(b => b.Id == searchId && completedStatuses.Contains(b.Status));
            }
            else
            {
                query = query.Where(b => false);
            }
        }
        else
        {
            if (completedStatusFilter == "All")
            {
                query = query.Where(b => completedStatuses.Contains(b.Status));
            }
            else
            {
                query = query.Where(b => b.Status == completedStatusFilter);
            }
        }
        
        totalCompletedBets = await query.CountAsync();
        completedBets = await query
            .OrderByDescending(b => b.UpdatedAt)
            .Skip((completedPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
        hasMoreCompletedBets = totalCompletedBets > (completedPage * pageSize);
        await PopulateUserLookup(completedBets.Select(b => b.UserId));
    }

    private async Task NextPage() { completedPage++; await LoadCompletedBets(); }
    private async Task PrevPage() { if (completedPage > 1) { completedPage--; await LoadCompletedBets(); } }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
             try
            {
                TimezoneOffset = await JSRuntime.InvokeAsync<int>("getBrowserTimeZoneOffset");
                StateHasChanged(); 
            }
            catch (Exception ex) { Console.WriteLine($"Timezone error: {ex.Message}"); }

            hubConnection = new HubConnectionBuilder().WithUrl(Nav.ToAbsoluteUri("/bethub")).Build();
            
            System.Timers.Timer? debounceTimer = null;
            
            hubConnection.On<string>("ReceiveAdminNotification", (message) =>
            {
                if (!string.IsNullOrEmpty(message) && message != "Update") successMessage = message;
                
                if (debounceTimer == null)
                {
                    debounceTimer = new System.Timers.Timer(1000);
                    debounceTimer.AutoReset = false;
                    debounceTimer.Elapsed += async (s, e) => 
                    {
                        await InvokeAsync(async () =>
                        {
                            await LoadPendingBets();
                            await LoadApprovedBets(); 
                            await LoadCompletedBets();
                            StateHasChanged();
                        });
                    };
                }
                
                debounceTimer.Stop();
                debounceTimer.Start();
                
                InvokeAsync(StateHasChanged);
            });
            await hubConnection.StartAsync();
            await hubConnection.InvokeAsync("JoinAdminGroup");
        }
        if (shouldFocusReviewModal) { shouldFocusReviewModal = false;
            try { await reviewModalRef.FocusAsync(); } catch { } }
    }

    private bool ShowOddsLookup = false;
    private bool IsSearchingOdds = false;
    private string OddsSearchTeam = "";
    
    // Kambi UI State
    private BettingApp.Services.KambiEvent? SelectedKambiEvent = null;
    private List<BettingApp.Services.KambiBetOffer>? AllKambiMarkets = null;
    private List<string> AvailableMarketCategories = new();
    private string SelectedKambiCategory = "";

    // AI Vision State
    private bool IsAnalyzingImage = false;
    private BettingApp.Services.AiVisionExtractionResult? AiVisionResult = null;
    private BettingApp.Services.AiVisionLeg? ActiveLookupLeg = null;
    private string? AiVisionError = null;

    private async Task AnalyzeImageAsync()
    {
        if (reviewingBetModel == null || string.IsNullOrEmpty(reviewingBetModel.ScreenshotUrl)) return;
        
        IsAnalyzingImage = true;
        AiVisionResult = null;
        ActiveLookupLeg = null;
        AiVisionError = null;
        StateHasChanged();

        var (result, error) = await AiVision.ExtractBetSlipDataAsync(reviewingBetModel.ScreenshotUrl);
        IsAnalyzingImage = false;
        
        if (error != null)
        {
            AiVisionError = error;
        }
        else if (result != null)
        {
            AiVisionResult = result;
            
            // Populate the UI input fields automatically
            if (!string.IsNullOrEmpty(result.TotalOdds))
            {
                // Try parsing with both comma and dot for safety
                var cleanOdds = result.TotalOdds.Replace(",", ".");
                if (decimal.TryParse(cleanOdds, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal odds))
                {
                    reviewingBetModel.Odds = odds;
                }
            }

            if (!string.IsNullOrEmpty(result.Stake))
            {
                var rawStake = result.Stake.Trim().ToLower();
                
                int multiplier = 1;
                if (rawStake.EndsWith("k"))
                {
                    multiplier = 1000;
                }
                else if (rawStake.EndsWith("m"))
                {
                    multiplier = 1000000;
                }

                var cleanStake = new string(rawStake.Where(c => char.IsDigit(c) || c == '.' || c == ',').ToArray());
                cleanStake = cleanStake.Replace(",", "."); // Handle European decimals

                if (decimal.TryParse(cleanStake, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out decimal stakeDecimal))
                {
                    reviewingBetModel.AmountNOK = (int)(stakeDecimal * multiplier);
                }
            }
            
            // Auto-fill the Kambi search for the FIRST leg to save time!
            if (result.Legs != null && result.Legs.Any())
            {
                SearchOddsForLeg(result.Legs.First());
            }
        }

        StateHasChanged();
    }

    private void SearchOddsForLeg(BettingApp.Services.AiVisionLeg leg)
    {
        ActiveLookupLeg = leg;
        if (string.IsNullOrEmpty(leg.Match)) return;
        
        var homeTeam = leg.Match.Split(new[] { " vs ", " v ", " - " }, StringSplitOptions.None)[0];
        var homeWords = homeTeam.Split(new[] { ' ' }, StringSplitOptions.RemoveEmptyEntries);
        
        OddsSearchTeam = string.Join(" ", homeWords.Take(2));
        ShowOddsLookup = true;
        _ = SearchOdds(leg.Market);
    }

    private string? OddsLookupErrorMessage = null;
    private string? OddsLookupWarningMessage = null;
    
    private async Task ToggleOddsLookup()
    {
        ShowOddsLookup = !ShowOddsLookup;
    }

    private async Task SearchOdds(string? preSelectCategory = null)
    {
        if (string.IsNullOrWhiteSpace(OddsSearchTeam)) return;

        IsSearchingOdds = true;
        OddsLookupErrorMessage = null;
        OddsLookupWarningMessage = null;
        SelectedKambiEvent = null;
        AllKambiMarkets = null;
        AvailableMarketCategories.Clear();
        SelectedKambiCategory = "";
        StateHasChanged();

        var (events, error) = await KambiScraper.SearchEventsAsync(OddsSearchTeam);
        
        if (error != null)
        {
            OddsLookupErrorMessage = error;
        }
        else if (events.Any())
        {
            SelectedKambiEvent = events.First();
            
            var (markets, marketError) = await KambiScraper.GetEventMarketsAsync(SelectedKambiEvent.Id);
            if (marketError != null)
            {
                OddsLookupErrorMessage = marketError;
            }
            else
            {
                AllKambiMarkets = markets;
                AvailableMarketCategories = markets
                    .Select(m => m.Criterion.EnglishLabel)
                    .Where(l => !string.IsNullOrEmpty(l))
                    .Distinct()
                    .OrderBy(l => l)
                    .ToList();
                    
                if (!string.IsNullOrEmpty(preSelectCategory))
                {
                    // 1. Normalize the market name using our dictionary
                    var normalizedTarget = MarketMapper.NormalizeMarketName(preSelectCategory);

                    // 2. Generic robust match: ignore spaces, punctuation, casing, and plurals/possessives
                    var simplify = (string s) => 
                    {
                        var clean = s.ToLowerInvariant()
                                     .Replace("players", "player")
                                     .Replace("player's", "player")
                                     .Replace("shots", "shot")
                                     .Replace("cards", "card")
                                     .Replace("goals", "goal")
                                     .Replace("corners", "corner");
                        return new string(clean.Where(char.IsLetterOrDigit).ToArray());
                    };
                    var simplifiedTarget = simplify(normalizedTarget);

                    var bestMatch = AvailableMarketCategories.FirstOrDefault(c => 
                        simplify(c) == simplifiedTarget || 
                        simplify(c).Contains(simplifiedTarget) ||
                        simplifiedTarget.Contains(simplify(c)));
                    if (bestMatch != null) 
                    {
                        SelectedKambiCategory = bestMatch;
                    }
                    else
                    {
                        OddsLookupWarningMessage = $"AI requested market '{preSelectCategory}', but Kambi doesn't offer it for this game.";
                    }
                }
                
                // Fallbacks if no preSelectCategory or fuzzy match failed
                if (string.IsNullOrEmpty(SelectedKambiCategory))
                {
                    if (AvailableMarketCategories.Contains("Full Time")) SelectedKambiCategory = "Full Time";
                    else if (AvailableMarketCategories.Contains("Match Odds")) SelectedKambiCategory = "Match Odds";
                    else SelectedKambiCategory = AvailableMarketCategories.FirstOrDefault() ?? "";
                }
            }
        }
        else
        {
            OddsLookupErrorMessage = "No Kambi matches found for that team.";
        }

        IsSearchingOdds = false;
        StateHasChanged();
    }

    private string KambiSearchQuery = "";
    private string? KambiTestOutput = null;
    private bool IsTestingKambi = false;

    private async Task TestKambi()
    {
        IsTestingKambi = true;
        KambiTestOutput = "Fetching Events...";
        StateHasChanged();
        
        var (results, error) = await KambiScraper.SearchEventsAsync(KambiSearchQuery);
        if (error != null) 
        {
            KambiTestOutput = error;
        } 
        else 
        {
            KambiTestOutput = $"Success! Found {results.Count} events.";
            if (results.Any()) {
                var firstEvent = results.First();
                KambiTestOutput += $"\nFirst event: {firstEvent.Name} ({firstEvent.Start})";
                
                KambiTestOutput += $"\n\nFetching Deep Markets for {firstEvent.Name}...";
                StateHasChanged();

                var (markets, marketError) = await KambiScraper.GetEventMarketsAsync(firstEvent.Id);
                
                if (marketError != null)
                {
                    KambiTestOutput += $"\nMarket Error: {marketError}";
                }
                else
                {
                    KambiTestOutput += $"\nFound {markets.Count} total markets!";
                    
                    // Group by market type and just show the counts of available markets
                    var grouped = markets.GroupBy(m => m.Criterion.EnglishLabel).OrderByDescending(g => g.Count());
                    
                    KambiTestOutput += "\n\nAvailable Markets:";
                    foreach(var g in grouped)
                    {
                        KambiTestOutput += $"\n- {g.Key} ({g.Count()} variants)";
                    }
                }
            }
        }
        
        IsTestingKambi = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) { await hubConnection.DisposeAsync(); }
    }

    private async Task<(bool allowed, string error)> CheckUserBalance(string userId, decimal newBetAmount)
    {
        using var context = DbFactory.CreateDbContext();
        var targetUser = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Id == userId);
        
        var currentBal = targetUser?.Balance ?? 0;
        var freeBetBal = targetUser?.FreeBetBalance ?? 0;
        var creditLimit = targetUser?.CreditLimit ?? 0;
        
        var availableCredit = currentBal + freeBetBal + creditLimit - newBetAmount;
        if (availableCredit < 0)
        {
            return (false, $"Insufficient funds. Available: {(currentBal + freeBetBal + creditLimit):N0} kr. Required: {newBetAmount:N0} kr.");
        }
        return (true, string.Empty);
    }

    private void StartReview(Bet bet)
    {
        if (pendingBets.Any(b => b.Id == bet.Id))
        {
            currentReviewList = pendingBets;
            reviewContext = "Pending";
            currentReviewIndex = pendingBets.FindIndex(b => b.Id == bet.Id);
        }
        else if (approvedBets.Any(b => b.Id == bet.Id))
        {
            currentReviewList = approvedBets;
            reviewContext = "Approved";
            currentReviewIndex = approvedBets.FindIndex(b => b.Id == bet.Id);
        }
        else if (completedBets.Any(b => b.Id == bet.Id))
        {
             currentReviewList = completedBets;
             reviewContext = "Completed";
             currentReviewIndex = completedBets.FindIndex(b => b.Id == bet.Id);
        }
        else
        {
            currentReviewList = new List<Bet> { bet };
            reviewContext = "Single";
            currentReviewIndex = 0;
        }

        originalBetModel = bet;
        reviewingBetModel = new Bet 
        { 
            Id = bet.Id, UserId = bet.UserId, UserName = bet.UserName, 
            AmountNOK = bet.AmountNOK, Odds = bet.Odds, Status = bet.Status, 
            FreeBetAmount = bet.FreeBetAmount,
            ScreenshotUrl = bet.ScreenshotUrl, CreatedAt = bet.CreatedAt
        };
        if (reviewingBetModel.Status == "Pending")
        {
            reviewingBetModel.Odds = 0;
        }

        modalSuccessMessage = null;
        reviewErrorMessage = null; errorMessage = null;
        AiVisionResult = null;
        AiVisionError = null;
        ShowOddsLookup = false;
        shouldFocusReviewModal = true;
    }

    private async Task CancelReview() 
    { 
        if (reviewingBetModel != null && originalBetModel != null)
        {
            if (originalBetModel.Status != "Pending" && (reviewingBetModel.Odds != originalBetModel.Odds || reviewingBetModel.AmountNOK != originalBetModel.AmountNOK))
            {
                 bool confirmed = await DialogService.ConfirmAsync( "You have unsaved changes to Odds or Stake.\n\nPlease click a status button (Won, Lost, Void) to save them, or click OK to discard changes and close.");
                 if (!confirmed) return;
            }
        }
        
        reviewingBetModel = null; 
        originalBetModel = null;
        reviewErrorMessage = null; 
        modalSuccessMessage = null; 
    }

    private bool CanNavigateReview(int direction)
    {
        if (currentReviewList == null || currentReviewList.Count == 0) return false;
        if (direction < 0) 
        {
            if (currentReviewIndex > 0) return true;
            if (reviewContext == "Approved") return approvedPage > 1;
            if (reviewContext == "Completed") return completedPage > 1;
            return false;
        }
        else 
        {
            if (currentReviewIndex < currentReviewList.Count - 1) return true;
            if (reviewContext == "Approved") return hasMoreApprovedBets;
            if (reviewContext == "Completed") return hasMoreCompletedBets;
            return false;
        }
    }

    private async Task NavigateReview(int direction)
    {
        if (currentReviewList == null || currentReviewList.Count == 0) return;
        modalSuccessMessage = null;
        AiVisionResult = null;
        AiVisionError = null;
        ShowOddsLookup = false;
        int newIndex = currentReviewIndex + direction;

        if (newIndex < 0) 
        {
            if (reviewContext == "Approved" && approvedPage > 1) {
                await PrevApprovedPage();
                currentReviewList = approvedBets;
                newIndex = currentReviewList.Count - 1;
            } 
            else if (reviewContext == "Completed" && completedPage > 1) {
                await PrevPage();
                currentReviewList = completedBets;
                newIndex = currentReviewList.Count - 1;
            }
            else {
                newIndex = 0; // Stick to 0 if we can't go back
            }
        }
        else if (newIndex >= currentReviewList.Count) 
        {
            if (reviewContext == "Approved" && hasMoreApprovedBets) {
                await NextApprovedPage();
                currentReviewList = approvedBets;
                newIndex = 0;
            }
            else if (reviewContext == "Completed" && hasMoreCompletedBets) {
                await NextPage();
                currentReviewList = completedBets;
                newIndex = 0;
            }
            else {
                newIndex = currentReviewList.Count - 1;
            }
        }

        if (newIndex != currentReviewIndex && newIndex >= 0 && newIndex < currentReviewList.Count)
        {
            var nextBet = currentReviewList[newIndex];
            StartReview(nextBet);
        }
    }

    private async Task OnReviewModalKeyDown(KeyboardEventArgs e) 
    { 
        if (e.Key == "ArrowRight") await NavigateReview(1);
        else if (e.Key == "ArrowLeft") await NavigateReview(-1);
    }

    private void HandleTouchStart(TouchEventArgs e) { touchStartX = e.Touches[0].ClientX; }

    private async Task HandleTouchEnd(TouchEventArgs e)
    {
        touchEndX = e.ChangedTouches[0].ClientX;
        var diff = touchStartX - touchEndX;
        if (Math.Abs(diff) > 50)
        {
            if (diff > 0) await NavigateReview(1);
            else await NavigateReview(-1);
        }
    }

    private async Task ProcessBet(Bet bet, string newStatus)
    {
        errorMessage = null;
        reviewErrorMessage = null;
        modalSuccessMessage = null; 
        string originalStatus = bet.Status;
        int originalBetId = bet.Id;
        if (newStatus != "Rejected" && newStatus != "Cancelled")
        {
            if (bet.AmountNOK == null || bet.AmountNOK <= 0) { reviewErrorMessage = "Invalid amount";
                return; }
            
            if (bet.Odds <= 1) { reviewErrorMessage = "Invalid odds";
                return; }
            
            if (Math.Round(bet.Odds, 2) != bet.Odds) { reviewErrorMessage = "Odds max 2 decimals";
                return; }

            bool isNewOrModified = originalStatus == "Pending" || (originalBetModel != null && (bet.AmountNOK != originalBetModel.AmountNOK || bet.Odds != originalBetModel.Odds));

            if (isNewOrModified)
            {
                using var validationContext = DbFactory.CreateDbContext();
                var settings = await validationContext.Settings.OrderBy(s => s.Id).FirstOrDefaultAsync();
                var betUser = await validationContext.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Id == bet.UserId);
                if (settings != null)
                {
                     if ((decimal)(bet.AmountNOK ?? 0) < settings.MinBetAmount) { 
                         reviewErrorMessage = $"Amount below limit ({settings.MinBetAmount:N0})";
                         return; 
                     }
                }
                
                if (betUser != null)
                {
                     decimal currentAmount = (decimal)(bet.AmountNOK ?? 0);
                     decimal netLiability = Math.Floor(currentAmount * (bet.Odds - 1));
                     decimal userLimit = betUser.MaxNetLiability;

                     if (netLiability > userLimit) { 
                         decimal maxBetAmount = Math.Floor(userLimit / (bet.Odds - 1));
                         reviewErrorMessage = $"Net liability exceeds limit ({userLimit:N0} kr). Max bet for {bet.Odds} odds is {maxBetAmount:N0} kr.";
                         return; 
                     }
                }
            }
        }

        if (new[] { "Won", "Lost", "Void", "Completed", "Cancelled" }.Contains(originalStatus))
        {
             bool confirmed = await DialogService.ConfirmAsync( 
                $"Update Bet #{bet.Id}?\n\n{originalStatus} -> {newStatus}\nAmount: {bet.AmountNOK} kr\nOdds: {bet.Odds}");
             if (!confirmed) return;
        }

        if (newStatus == "Approved" || newStatus == "Won" || newStatus == "Lost")
        {
            if (originalStatus == "Pending")
            {
                var (allowed, error) = await CheckUserBalance(bet.UserId, (decimal)(bet.AmountNOK ?? 0));
                if (!allowed)
                {
                    reviewErrorMessage = error;
                    StateHasChanged();
                    return;
                }
            }
        }
        
        using var context = DbFactory.CreateDbContext();
        var dbBet = await context.Bets.FindAsync(bet.Id);
        var dbUser = await context.Users.FindAsync(bet.UserId);
        if (dbBet != null && dbUser != null)
        {
            if (dbBet.Status != originalStatus)
            {
                 errorMessage = $"Action aborted: Bet #{bet.Id} was already updated to '{dbBet.Status}' by another admin.";
                 await LoadPendingBets();
                 await LoadApprovedBets();
                 await LoadCompletedBets();
                 StateHasChanged();
                 return;
            }

            decimal dbAmount = (decimal)(dbBet.AmountNOK ?? 0);

            // REVERSE OLD IMPACT
            // Statuses that have deducted balance: Approved, Won, Lost
            if (originalStatus == "Approved" || originalStatus == "Lost")
            {
                dbUser.Balance += (dbAmount - dbBet.FreeBetAmount);
                dbUser.FreeBetBalance += dbBet.FreeBetAmount;
            }
            else if (originalStatus == "Won")
            {
                dbUser.Balance += (dbAmount - dbBet.FreeBetAmount);
                dbUser.FreeBetBalance += dbBet.FreeBetAmount;
                dbUser.Balance -= dbBet.PotentialPayout;
            }
            // originalStatus == Void/Rejected/Cancelled/Pending already has balance returned

            // APPLY NEW VALUES
            dbBet.Status = newStatus;
            dbBet.AmountNOK = bet.AmountNOK;
            dbBet.Odds = bet.Odds;

            decimal newAmount = (decimal)(dbBet.AmountNOK ?? 0);

            if (originalStatus == "Pending")
            {
                // Automatic consumption if user has free bet balance
                dbBet.FreeBetAmount = Math.Min(newAmount, dbUser.FreeBetBalance);
            }
            else 
            {
                 // Safety: Capping free bet amount if admin reduced the total stake
                 dbBet.FreeBetAmount = Math.Min(dbBet.FreeBetAmount, newAmount);
            }

            // APPLY NEW STATUS IMPACT
            // Statuses that should deduct balance: Approved, Won, Lost
            if (newStatus == "Approved" || newStatus == "Lost")
            {
                dbUser.Balance -= (newAmount - dbBet.FreeBetAmount);
                dbUser.FreeBetBalance -= dbBet.FreeBetAmount;
            }
            else if (newStatus == "Won")
            {
                dbUser.Balance -= (newAmount - dbBet.FreeBetAmount);
                dbUser.FreeBetBalance -= dbBet.FreeBetAmount;
                dbUser.Balance += dbBet.PotentialPayout;
            }
            // newStatus == Void/Rejected/Cancelled doesn't deduct stakes

            dbBet.UpdatedAt = DateTime.UtcNow;
            context.AuditLogs.Add(new AuditLog
            {
                AdminUserName = currentAdminName ?? "Unknown",
                Action = $"Bet {newStatus}",
                TargetUserName = bet.UserName,
                Details = $"Bet ID: {bet.Id}, Status: {newStatus}, Amount: {dbBet.AmountNOK}, FreeBetPart: {dbBet.FreeBetAmount}, Payout: {dbBet.PotentialPayout:N0}"
            });
            await context.SaveChangesAsync();
        }

        await LoadPendingBets();
        await LoadApprovedBets();
        await LoadCompletedBets();
        if (dbUser != null && !string.IsNullOrEmpty(dbUser.DiscordUserId))
        {
            _ = DiscordService.NotifyUserBetAsync(dbUser.DiscordUserId, dbBet!, newStatus, isUpdate: false);
        }

        await HubContext.Clients.Group(bet.UserId).SendAsync("ReceiveUpdate", $"Your bet status is now: {newStatus}");
        await HubContext.Clients.Group("Admins").SendAsync("ReceiveAdminNotification", "Update");
        modalSuccessMessage = $"Bet #{bet.Id} updated.";
        
        if (reviewContext == "Pending") currentReviewList = pendingBets;
        else if (reviewContext == "Approved") currentReviewList = approvedBets;
        else if (reviewContext == "Completed") currentReviewList = completedBets;
        else { }

        if (currentReviewList.Count > 0)
        {
            if (currentReviewIndex >= currentReviewList.Count) 
            {
                reviewingBetModel = null;
                successMessage = $"Finished processing. Queue empty.";
            }
            else
            {
                var actualNextBet = currentReviewList[currentReviewIndex];
                StartReview(actualNextBet);
                modalSuccessMessage = null;
            }
        }
        else
        {
            reviewingBetModel = null;
            modalSuccessMessage = null; 
            successMessage = $"Bet #{bet.Id} processed. Queue empty.";
        }
        StateHasChanged();
    }

    // --- CSV EXPORT FUNCTIONALITY ---
    private async Task ExportPendingBetsCsv()
    {
        using var context = DbFactory.CreateDbContext();
        var bets = await context.Bets.Where(b => b.Status == "Pending").OrderByDescending(b => b.UpdatedAt).ToListAsync();
        await GenerateAndDownloadCsv(bets, "PendingBets.csv", "Pending");
    }

    private async Task ExportActiveBetsCsv()
    {
        using var context = DbFactory.CreateDbContext();
        var bets = await context.Bets.Where(b => b.Status == "Approved").OrderByDescending(b => b.UpdatedAt).ToListAsync();
        await GenerateAndDownloadCsv(bets, "ActiveBets.csv", "Active");
    }

    private async Task ExportCompletedBetsCsv()
    {
        using var context = DbFactory.CreateDbContext();
        var completedStatuses = new[] { "Won", "Lost", "Void", "Rejected", "Cancelled" };
        var bets = await context.Bets.Where(b => completedStatuses.Contains(b.Status)).OrderByDescending(b => b.UpdatedAt).ToListAsync();
        await GenerateAndDownloadCsv(bets, "CompletedBets.csv", "Completed");
    }

    private async Task GenerateAndDownloadCsv(List<Bet> bets, string filename, string exportType)
    {
        await PopulateUserLookup(bets.Select(b => b.UserId));
        var sb = new System.Text.StringBuilder();

        string header = "ID,LastUpdatedLocal,LastUpdatedNorway,DiscordUsername,LastName,BetAmount,Odds,PotentialPayout,Status";
        if (exportType == "Active") header += ",NetLiability";
        if (exportType == "Completed") header += ",NetProfit";
        
        sb.AppendLine(header);

        foreach (var bet in bets)
        {
            var localTime = ToUserLocal(bet.UpdatedAt).ToString("g");
            var norwayTime = TimeHelpers.GetNorwayTime(bet.UpdatedAt).ToString("g");
            var discordName = userLookup.TryGetValue(bet.UserId, out var u) && !string.IsNullOrEmpty(u.DiscordName) ? u.DiscordName : bet.UserName;
            var lastName = userLookup.TryGetValue(bet.UserId, out var u2) ? u2.LastName : "";

            var line = $"{bet.Id},{EscapeCsv(localTime)},{EscapeCsv(norwayTime)},{EscapeCsv(discordName)},{EscapeCsv(lastName)},{bet.AmountNOK?.ToString()},{bet.Odds},{bet.PotentialPayout},{bet.Status}";

            if (exportType == "Active")
            {
                var netLiability = bet.PotentialPayout - ((decimal)(bet.AmountNOK ?? 0) - bet.FreeBetAmount);
                line += $",{netLiability}";
            }
            if (exportType == "Completed")
            {
                var netProfit = GetNetProfit(bet);
                line += $",{netProfit}";
            }

            sb.AppendLine(line);
        }

        await JSRuntime.InvokeVoidAsync("downloadCsv", filename, sb.ToString());
    }

    private string EscapeCsv(string field)
    {
        if (string.IsNullOrEmpty(field)) return "";
        // Escape existing quotes
        field = field.Replace("\"", "\"\"");
        
        // Wrap in quotes if it contains commas, quotes, or newlines
        if (field.Contains(",") || field.Contains("\"") || field.Contains("\n") || field.Contains("\r"))
        {
            return $"\"{field}\"";
        }
        
        return field;
    }
