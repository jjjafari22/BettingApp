                            <td>@(userLookup.TryGetValue(bet.UserId, out var u2) ? u2.LastName : "")</td>
                            <td>
                                @bet.AmountNOK?.ToString("N0") kr
                                @if (bet.FreeBetAmount > 0) {
                                    <br/><span class="badge bg-info text-dark small"><i class="bi bi-gift-fill"></i> Free Bet</span>
