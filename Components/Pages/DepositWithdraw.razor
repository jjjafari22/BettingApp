@page "/deposit-withdraw"
@rendermode @(new InteractiveServerRenderMode(prerender: true))
@using BettingApp.Data
@using BettingApp.Services
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.SignalR
@using BettingApp.Hubs
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime
@inject IHubContext<BetHub> HubContext
@inject DiscordNotificationService DiscordService
@attribute [Authorize]
@implements IAsyncDisposable

<PageTitle>Deposit / Withdrawal</PageTitle>

@if (IsLoading)
{
    <div class="alert alert-info">Loading...</div>
}

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show">
        @ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        @SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

<div class="container mt-4">
    <div class="row">
        @* Deposit Section *@
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-success text-white">Deposit</div>
                <div class="card-body d-flex flex-column justify-content-center align-items-center text-center">
                    <p class="card-text fs-5">
                        We accept PayPal, Vipps, Revolut and Crypto.<br/><br/>
                        Please reach out to us on 
                        <a href="https://discord.gg/rNnsQWENMs" target="_blank" rel="noopener noreferrer" class="fw-bold">Discord</a> or 
                        <a href="https://m.me/61587418012797" target="_blank" rel="noopener noreferrer" class="fw-bold">Facebook Messenger</a> 
                        to finalize deposit details.
                    </p>
                </div>
            </div>
        </div>

        @* Withdrawal Section *@
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark">Withdrawal Request</div>
                <div class="card-body">
                    <p class="mb-0">Current Balance: <strong>@Balance.ToString("N0") kr</strong></p>
                    @if (FreeBetBalance > 0)
                    {
                        <p class="mb-0 text-info small"><i class="bi bi-gift-fill"></i> Free Bet Balance: <strong>@FreeBetBalance.ToString("N0") kr</strong></p>
                    }
                    <p class="text-muted small mb-3">
                        <i class="bi bi-info-circle"></i> Withdrawals must be requested before kl. 23:59 of the day before settlements (usually before 23:59 on Sunday's).<br/>
                        <i class="bi bi-exclamation-triangle"></i> Withdrawals requested outside of the standard payment day is subject to a 20% fee.
                    </p>
                    
                    <EditForm Model="@withdrawalRequest" OnValidSubmit="RequestWithdrawal" FormName="WithdrawForm">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Amount (NOK)</label>
                            <InputNumber @bind-Value="withdrawalAmount" class="form-control form-control-lg" />
                        </div>
                        
                        <div class="alert alert-info py-2 small shadow-sm">
                            <i class="bi bi-info-circle-fill me-1"></i> We strongly recommend providing <u class="fw-bold">Vipps and Revolut</u> so that we can send out your money faster. The more options you provide, the better!
                        </div>

                        <div class="card bg-light border-0 mb-3 shadow-sm">
                            <div class="card-body py-3 px-3">
                                <label class="form-label fw-semibold mb-2">Vipps</label>
                                <InputText @bind-Value="vippsDetails" class="form-control" placeholder="8-digit Norwegian Phone Number" />
                            </div>
                        </div>

                        <div class="card bg-light border-0 mb-3 shadow-sm">
                            <div class="card-body py-3 px-3">
                                <label class="form-label fw-semibold mb-2">Revolut</label>
                                <InputText @bind-Value="revolutDetails" class="form-control" placeholder="Revolut Tag / Username" />
                            </div>
                        </div>

                        <div class="card bg-light border-0 mb-4 shadow-sm">
                            <div class="card-body py-3 px-3">
                                <label class="form-label fw-semibold mb-2">Other Payment Method</label>
                                <div class="row g-2">
                                    <div class="col-md-5">
                                        <InputText @bind-Value="otherPlatformName" class="form-control" placeholder="e.g. PayPal" />
                                    </div>
                                    <div class="col-md-7">
                                        <InputText @bind-Value="otherDetails" class="form-control" placeholder="Receiving Info" />
                                    </div>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100" disabled="@IsSubmitting">
                            @if (IsSubmitting) { <span class="spinner-border spinner-border-sm"></span> }
                            else { <span>Request Withdrawal</span> }
                        </button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>

    @* Transactions History *@
    <h4 class="mt-4">My Transactions (@totalTransactions)</h4>
    <div class="table-responsive">
        <table class="table table-sm table-striped table-hover align-middle text-nowrap">
            <thead class="table-dark">
                <tr>
                    <th>Last Updated</th>
                    <th>Type</th>
                    <th>Payment Method</th>
                    <th>Amount</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (myTransactions.Count == 0)
                {
                    <tr><td colspan="5" class="text-center text-muted">No transactions found.</td></tr>
                }
                @foreach (var t in myTransactions)
                {
                    <tr>
                        <td>@ToUserLocal(t.UpdatedAt).ToString("g")</td>
                        <td>
                            @if (t.Type == "Deposit")
                            {
                                <span class="badge bg-success">Deposit</span>
                            }
                            else if (t.Type == "Free Bet")
                            {
                                <span class="badge bg-info text-dark">Free Bet</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">@t.Type</span>
                            }
                        </td>
                        <td>
                            @t.Platform
                            @if((t.Type == "Withdrawal" || t.Type == "Free Bet") && !string.IsNullOrEmpty(t.PaymentDetails)) {
                                <br/><small class="text-muted">@t.PaymentDetails</small>
                            }
                        </td>
                        <td>@t.AmountNOK.ToString("N0") kr</td>
                         <td>
                            <span class="badge @GetStatusBadge(t.Status)">@t.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="d-flex justify-content-between align-items-center mt-2 mb-5">
        <button class="btn btn-outline-secondary btn-sm" @onclick="PrevTransPage" disabled="@(transPage <= 1)">
            <i class="bi bi-arrow-left"></i> Previous
        </button>
        <span class="text-muted">Page @transPage</span>
        <button class="btn btn-outline-secondary btn-sm" @onclick="NextTransPage" disabled="@(!hasMoreTrans)">
            Next <i class="bi bi-arrow-right"></i>
        </button>
    </div>
</div>

@if (showOneMethodWarning)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-warning text-dark border-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Just one payment method?</h5>
                    <button type="button" class="btn-close" @onclick="() => showOneMethodWarning = false"></button>
                </div>
                <div class="modal-body py-4">
                    <p class="fs-5 mb-2">We noticed you only provided one payment method.</p>
                    <p class="mb-0 text-muted">We highly recommend adding at least two options so that you will get paid faster.</p>
                </div>
                <div class="modal-footer bg-light border-0">
                    <button type="button" class="btn btn-outline-secondary fw-bold" @onclick="() => showOneMethodWarning = false">Add more payment methods</button>
                    <button type="button" class="btn btn-primary fw-bold px-4 shadow-sm" @onclick="ConfirmWithdrawal">Withdraw anyways</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private Transaction withdrawalRequest = new() { Type = "Withdrawal", Platform = "Pending" };
    private int? withdrawalAmount;
    private string vippsDetails = "";
    private string revolutDetails = "";
    private string otherPlatformName = "";
    private string otherDetails = "";
    private bool showOneMethodWarning = false;
    private List<Transaction> myTransactions = new();
    private decimal Balance = 0;
    private decimal FreeBetBalance = 0;
    private string userId = string.Empty;
    private bool IsLoading = true;
    private bool IsSubmitting = false;
    private string? ErrorMessage;
    private string? SuccessMessage;
    private int transPage = 1;
    private bool hasMoreTrans = false;
    private int totalTransactions = 0;
    private const int PageSize = 20;

    private HubConnection? hubConnection;
    private int TimezoneOffset { get; set; }

    private DateTime ToUserLocal(DateTime utcDate)
    {
        if (utcDate == DateTime.MinValue || utcDate == DateTime.MaxValue) return utcDate;
        return utcDate.AddMinutes(-TimezoneOffset);
    }

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        userId = auth.User.FindFirst(u => u.Type.Contains("nameidentifier"))?.Value ?? "";
        
        if (string.IsNullOrEmpty(userId))
        {
            Nav.NavigateTo("/Account/Login");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                TimezoneOffset = await JSRuntime.InvokeAsync<int>("getBrowserTimeZoneOffset");
                if (!string.IsNullOrEmpty(userId))
                {
                    await LoadData();
                    await SetupSignalR();
                }
            }
            catch (Exception ex) { Console.WriteLine(ex); }
            finally { IsLoading = false; StateHasChanged(); }
        }
    }

    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/bethub"))
            .Build();
        hubConnection.On<string>("ReceiveUpdate", async (message) =>
        {
            await LoadData();
            await InvokeAsync(StateHasChanged);
        });
        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("JoinUserGroup", userId);
    }

    private async Task LoadData()
    {
        using var context = DbFactory.CreateDbContext();
        var user = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.Id == userId);
        
        if (user != null)
        {
            Balance = user.Balance;
            FreeBetBalance = user.FreeBetBalance;
        }

        totalTransactions = await context.Transactions.CountAsync(t => t.UserId == userId);
        myTransactions = await context.Transactions
            .Where(t => t.UserId == userId)
            .OrderByDescending(t => t.UpdatedAt)
            .Skip((transPage - 1) * PageSize)
            .Take(PageSize)
            .AsNoTracking()
            .ToListAsync();
        hasMoreTrans = totalTransactions > (transPage * PageSize);
    }

    private async Task RequestWithdrawal()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        
        await LoadData(); 

        if (!withdrawalAmount.HasValue || withdrawalAmount.Value <= 0)
        {
            ErrorMessage = "Amount must be greater than 0.";
            return;
        }

        if (withdrawalAmount.Value > Balance)
        {
            ErrorMessage = "You cannot withdraw more than your current balance.";
            return;
        }

        bool hasVipps = !string.IsNullOrWhiteSpace(vippsDetails);
        bool hasRevolut = !string.IsNullOrWhiteSpace(revolutDetails);
        bool hasOther = !string.IsNullOrWhiteSpace(otherPlatformName) && !string.IsNullOrWhiteSpace(otherDetails);

        int methodsCount = (hasVipps ? 1 : 0) + (hasRevolut ? 1 : 0) + (hasOther ? 1 : 0);

        if (methodsCount == 0)
        {
            ErrorMessage = "Please provide at least one payment method to receive your withdrawal.";
            return;
        }

        if (methodsCount == 1)
        {
            showOneMethodWarning = true;
            return;
        }

        await ExecuteWithdrawal();
    }

    private async Task ConfirmWithdrawal()
    {
        showOneMethodWarning = false;
        await ExecuteWithdrawal();
    }

    private async Task ExecuteWithdrawal()
    {
        IsSubmitting = true;
        try 
        {
            bool hasVipps = !string.IsNullOrWhiteSpace(vippsDetails);
            bool hasRevolut = !string.IsNullOrWhiteSpace(revolutDetails);
            bool hasOther = !string.IsNullOrWhiteSpace(otherPlatformName) && !string.IsNullOrWhiteSpace(otherDetails);

            using var context = DbFactory.CreateDbContext();
            var auth = await AuthState.GetAuthenticationStateAsync();
            var userName = auth.User.Identity?.Name ?? "Unknown";
            
            var user = await context.Users.FindAsync(userId);
            if (user != null)
            {
                user.Balance -= withdrawalAmount!.Value;
            }
            
            var providedMethods = new List<string>();
            string primaryPlatform = "Mixed";
            
            if (hasVipps)
            {
                providedMethods.Add($"Vipps: {vippsDetails.Trim()}");
                primaryPlatform = "Vipps";
            }
            if (hasRevolut)
            {
                providedMethods.Add($"Revolut: {revolutDetails.Trim()}");
                if (primaryPlatform == "Mixed") primaryPlatform = "Revolut";
                else primaryPlatform = "Multiple";
            }
            if (hasOther)
            {
                providedMethods.Add($"{otherPlatformName.Trim()}: {otherDetails.Trim()}");
                if (primaryPlatform == "Mixed") primaryPlatform = otherPlatformName.Trim();
                else primaryPlatform = "Multiple";
            }

            string finalDetails = string.Join(" | ", providedMethods);

            var transaction = new Transaction
            {
                UserId = userId,
                UserName = userName,
                Type = "Withdrawal",
                AmountNOK = withdrawalAmount!.Value,
                Platform = primaryPlatform,
                PaymentDetails = finalDetails,
                Date = DateTime.UtcNow,
                UpdatedAt = DateTime.UtcNow,
                Status = "Pending"
            };
            
            context.Transactions.Add(transaction);
            await context.SaveChangesAsync();

            await DiscordService.NotifyAdminWithdrawalAsync(transaction);
            await HubContext.Clients.Group("Admins").SendAsync("ReceiveAdminNotification", "New withdrawal request");
            
            SuccessMessage = "Withdrawal request submitted successfully. Waiting for admin approval.";
            withdrawalAmount = null;
            vippsDetails = "";
            revolutDetails = "";
            otherPlatformName = "";
            otherDetails = "";
            await LoadData();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private async Task NextTransPage() { transPage++; await LoadData(); }
    private async Task PrevTransPage() { if (transPage > 1) { transPage--; await LoadData(); } }

    private string GetStatusBadge(string status) => status switch
    {
        "Completed" => "bg-success",
        "Pending" => "bg-warning text-dark",
        "Rejected" => "bg-danger",
        _ => "bg-secondary"
    };

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null) await hubConnection.DisposeAsync();
    }
}