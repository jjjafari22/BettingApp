@page "/admin/creditlimits"
@using BettingApp.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.SignalR.Client
@using Microsoft.AspNetCore.SignalR
@using System.Globalization
@using BettingApp.Hubs
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav
@inject IHubContext<BetHub> HubContext
@inject BettingApp.Services.DialogService DialogService
@rendermode InteractiveServer
@implements IAsyncDisposable

<h3>Credit/Payout Limits</h3>

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-4 shadow" role="alert" style="z-index: 1055; min-width: 300px;">
        <i class="bi bi-check-circle-fill me-2"></i> @successMessage
        <button type="button" class="btn-close" @onclick="() => successMessage = null"></button>
    </div>
}

@if (!isAdmin)
{
    <p>You are not authorized to view this page.</p>
}
else if (userRows == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="row mb-3 align-items-center">
         <div class="col-md-6">
            <div class="input-group">
                <span class="input-group-text">Search User</span>
                <input type="text" class="form-control" placeholder="Username (Press Enter to search)..." 
                     @bind="SearchTerm" />
            </div>
        </div>
        <div class="col-md-6 text-end">
            <span class="text-muted fw-bold me-3">Total Users: @totalUsers</span>
        </div>
     </div>

    <div class="table-responsive mb-4">
        <table class="table table-sm table-striped table-hover align-middle text-nowrap">
            <thead class="table-dark">
                <tr>
                    <th class="text-nowrap" style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("UpdatedAt"))">Last Updated <i class="@SortIconClass("UpdatedAt")"></i></th>
                    <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("DiscordUsername"))">Discord Username <i class="@SortIconClass("DiscordUsername")"></i></th>
                     <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("LastName"))">Last Name <i class="@SortIconClass("LastName")"></i></th>
                     <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("NumDeposits"))"># Dep <i class="@SortIconClass("NumDeposits")"></i></th>
                     <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("TotalDeposits"))">Total Dep <i class="@SortIconClass("TotalDeposits")"></i></th>
                     <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("NumWithdrawals"))"># W/D <i class="@SortIconClass("NumWithdrawals")"></i></th>
                     <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("TotalWithdrawals"))">Total W/D <i class="@SortIconClass("TotalWithdrawals")"></i></th>
                    <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("CreditLimit"))">Credit Limit (NOK) <i class="@SortIconClass("CreditLimit")"></i></th>
                    <th style="cursor:pointer; user-select:none;" @onclick="@(() => SortBy("MaxNetLiability"))">Max Liability (NOK) <i class="@SortIconClass("MaxNetLiability")"></i></th>
                </tr>
            </thead>
            <tbody>
                 @foreach (var row in FilteredUsers)
                {
                    <tr @key="GetRowKey(row.User.Id)">
                        <td class="text-nowrap">@ToUserLocal(row.User.UpdatedAt).ToString("g")</td>
                        <td>@(!string.IsNullOrEmpty(row.User.DiscordUsername) ? row.User.DiscordUsername : row.User.UserName)</td>
                        <td>@row.User.LastName</td>
                        <td>@row.NumDeposits</td>
                        <td class="text-success fw-bold">@row.TotalDeposits.ToString("N0") kr</td>
                        <td>@row.NumWithdrawals</td>
                        <td class="text-danger fw-bold">@row.TotalWithdrawals.ToString("N0") kr</td>
                        <td>
                            <input type="text" class="form-control form-control-sm" style="width: 120px;" value="@row.User.CreditLimit.ToString("N0")"
                                   @onchange="@(async (e) => await UpdateLimit(row.User, e.Value?.ToString(), isCredit: true))" />
                        </td>
                        <td>
                             <input type="text" class="form-control form-control-sm" style="width: 120px;" value="@row.User.MaxNetLiability.ToString("N0")"
                                   @onchange="@(async (e) => await UpdateLimit(row.User, e.Value?.ToString(), isCredit: false))" />
                        </td>
                    </tr>
                 }
                 @if (!FilteredUsers.Any())
                 {
                     <tr><td colspan="9" class="text-center text-muted">No users found.</td></tr>
                 }
            </tbody>
        </table>
        
        <div class="d-flex justify-content-between align-items-center mt-2">
            <button class="btn btn-sm @(currentPage <= 1 ? "btn-outline-secondary" : "btn-primary shadow-sm")" @onclick="PrevPage" disabled="@(currentPage <= 1)"><i class="bi bi-arrow-left"></i> Previous</button>
            <span class="text-muted fw-bold">Page @currentPage</span>
            <button class="btn btn-sm @(!hasMoreUsers ? "btn-outline-secondary" : "btn-primary shadow-sm fw-bold")" @onclick="NextPage" disabled="@(!hasMoreUsers)">Next <i class="bi bi-arrow-right"></i></button>
        </div>
    </div>
}

@code {
    private class UserCreditRow
    {
        public ApplicationUser User { get; set; } = new();
        public int NumDeposits { get; set; }
        public decimal TotalDeposits { get; set; }
        public int NumWithdrawals { get; set; }
        public decimal TotalWithdrawals { get; set; }
    }

    private List<UserCreditRow>? userRows;
    private string _searchTerm = "";
    private string SearchTerm 
    { 
        get => _searchTerm; 
        set 
        { 
            _searchTerm = value;
            currentPage = 1;
            _ = LoadUsers(); 
        } 
    }
    
    private bool isAdmin = false;
    private string? successMessage; 
    private string? currentAdminName;
    private int TimezoneOffset { get; set; }
    private HubConnection? hubConnection;
    private Dictionary<string, Guid> rowKeys = new();
    
    private int currentPage = 1;
    private int pageSize = 25;
    private int totalUsers = 0;
    private bool hasMoreUsers = false;

    private IEnumerable<UserCreditRow> FilteredUsers => userRows ?? new List<UserCreditRow>();

    private Guid GetRowKey(string userId)
    {
        if (!rowKeys.ContainsKey(userId))
        {
            rowKeys[userId] = Guid.NewGuid();
        }
        return rowKeys[userId];
    }

    private string sortColumn = "UpdatedAt";
    private bool sortDescending = true;

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortDescending = !sortDescending;
        else
        {
            sortColumn = column;
            sortDescending = true;
        }
        currentPage = 1;
        _ = LoadUsers();
    }

    private string SortIconClass(string column)
    {
        if (sortColumn != column) return "";
        return sortDescending ? "bi bi-arrow-down-short text-warning" : "bi bi-arrow-up-short text-warning";
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentAdminName = user.Identity?.Name;

        if (user.Identity?.IsAuthenticated == true)
        {
            using var context = DbFactory.CreateDbContext();
            var currentUser = await context.Users
                .AsNoTracking()
                .FirstOrDefaultAsync(u => u.UserName == user.Identity.Name);
            isAdmin = currentUser?.IsAdmin ?? false;
        }

        if (isAdmin)
        {
            await LoadUsers();
        }
    }
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try {
                TimezoneOffset = await JSRuntime.InvokeAsync<int>("getBrowserTimeZoneOffset");
                StateHasChanged();
            } catch { }
            
            if (isAdmin) {
                try { await SetupSignalR(); } catch { }
            }
        }
    }
    
    private async Task SetupSignalR()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/bethub"))
            .Build();
        hubConnection.On<string>("ReceiveAdminNotification", async (message) =>
        {
            await LoadUsers();
            await InvokeAsync(StateHasChanged);
        });
        await hubConnection.StartAsync();
        await hubConnection.InvokeAsync("JoinAdminGroup");
    }

    private DateTime ToUserLocal(DateTime utcDate)
    {
        if (utcDate == DateTime.MinValue) return utcDate;
        return utcDate.AddMinutes(-TimezoneOffset);
    }

    private async Task LoadUsers()
    {
        using var context = DbFactory.CreateDbContext();
        
        var baseQuery = context.Users.Where(u => !u.IsAdmin);
        
        if (!string.IsNullOrWhiteSpace(_searchTerm))
        {
            baseQuery = baseQuery.Where(u => 
                (u.DiscordUsername != null && u.DiscordUsername.Contains(_searchTerm)) || 
                (u.UserName != null && u.UserName.Contains(_searchTerm)));
        }

        totalUsers = await baseQuery.CountAsync();
        
        var query = baseQuery.Select(u => new 
        {
            User = u,
            NumDeposits = context.Transactions.Count(t => t.UserId == u.Id && t.Status == "Completed" && t.Type == "Deposit"),
            TotalDeposits = context.Transactions.Where(t => t.UserId == u.Id && t.Status == "Completed" && t.Type == "Deposit").Sum(t => (decimal?)t.AmountNOK) ?? 0m,
            NumWithdrawals = context.Transactions.Count(t => t.UserId == u.Id && t.Status == "Completed" && t.Type == "Withdrawal"),
            TotalWithdrawals = context.Transactions.Where(t => t.UserId == u.Id && t.Status == "Completed" && t.Type == "Withdrawal").Sum(t => (decimal?)t.AmountNOK) ?? 0m
        });

        if (sortColumn == "UpdatedAt")
            query = sortDescending ? query.OrderByDescending(x => x.User.UpdatedAt) : query.OrderBy(x => x.User.UpdatedAt);
        else if (sortColumn == "DiscordUsername")
            query = sortDescending ? query.OrderByDescending(x => x.User.DiscordUsername) : query.OrderBy(x => x.User.DiscordUsername);
        else if (sortColumn == "LastName")
            query = sortDescending ? query.OrderByDescending(x => x.User.LastName) : query.OrderBy(x => x.User.LastName);
        else if (sortColumn == "CreditLimit")
            query = sortDescending ? query.OrderByDescending(x => x.User.CreditLimit) : query.OrderBy(x => x.User.CreditLimit);
        else if (sortColumn == "MaxNetLiability")
            query = sortDescending ? query.OrderByDescending(x => x.User.MaxNetLiability) : query.OrderBy(x => x.User.MaxNetLiability);
        else if (sortColumn == "NumDeposits")
            query = sortDescending ? query.OrderByDescending(x => x.NumDeposits) : query.OrderBy(x => x.NumDeposits);
        else if (sortColumn == "TotalDeposits")
            query = sortDescending ? query.OrderByDescending(x => x.TotalDeposits) : query.OrderBy(x => x.TotalDeposits);
        else if (sortColumn == "NumWithdrawals")
            query = sortDescending ? query.OrderByDescending(x => x.NumWithdrawals) : query.OrderBy(x => x.NumWithdrawals);
        else if (sortColumn == "TotalWithdrawals")
            query = sortDescending ? query.OrderByDescending(x => x.TotalWithdrawals) : query.OrderBy(x => x.TotalWithdrawals);
        else
            query = query.OrderByDescending(x => x.User.UpdatedAt);

        var results = await query
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
            
        hasMoreUsers = totalUsers > (currentPage * pageSize);
        
        userRows = results.Select(r => new UserCreditRow {
            User = r.User,
            NumDeposits = r.NumDeposits,
            TotalDeposits = r.TotalDeposits,
            NumWithdrawals = r.NumWithdrawals,
            TotalWithdrawals = r.TotalWithdrawals
        }).ToList();
        
        StateHasChanged();
    }
    
    private async Task NextPage() { currentPage++; await LoadUsers(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadUsers(); } }

    private async Task UpdateLimit(ApplicationUser userToUpdate, string? newValueStr, bool isCredit)
    {
        decimal newValue = 0;
        var cleanStr = newValueStr?.Replace(" ", "").Replace("\u00A0", ""); 
        
        bool isValid = decimal.TryParse(cleanStr, NumberStyles.Any, CultureInfo.InvariantCulture, out newValue);
        if (!isValid)
        {
            rowKeys[userToUpdate.Id] = Guid.NewGuid();
            StateHasChanged();
            return;
        }

        string fieldName = isCredit ? "Credit Limit" : "Max Liability";
        var displayUser = !string.IsNullOrEmpty(userToUpdate.DiscordUsername) ? userToUpdate.DiscordUsername : userToUpdate.UserName;
        string msg = $"Are you sure you want to change {displayUser}'s {fieldName} to {newValue:N0} NOK?";
        bool confirmed = await DialogService.ConfirmAsync(msg);

        if (!confirmed)
        {
            rowKeys[userToUpdate.Id] = Guid.NewGuid();
            StateHasChanged();
            return;
        }

        using var context = DbFactory.CreateDbContext();
        var dbUser = await context.Users.FindAsync(userToUpdate.Id);
        if (dbUser != null)
        {
            string logDetails = "";
            if (isCredit)
            {
                var oldVal = dbUser.CreditLimit;
                dbUser.CreditLimit = (int)newValue;
                logDetails = $"CreditLimit: {oldVal:N0} -> {dbUser.CreditLimit:N0}";
            }
            else
            {
                var oldVal = dbUser.MaxNetLiability;
                dbUser.MaxNetLiability = newValue;
                logDetails = $"MaxNetLiability: {oldVal:N0} -> {dbUser.MaxNetLiability:N0}";
            }
            
            dbUser.UpdatedAt = DateTime.UtcNow;
            context.AuditLogs.Add(new AuditLog
            {
                AdminUserName = currentAdminName ?? "Unknown",
                Action = isCredit ? "Changed Credit Limit" : "Changed Max Liability",
                TargetUserName = userToUpdate.UserName ?? "Unknown",
                Details = logDetails
            });

            await context.SaveChangesAsync();
            await HubContext.Clients.Group("Admins").SendAsync("ReceiveAdminNotification", 
                $"{fieldName} updated for {displayUser}");
            successMessage = $"{fieldName} updated for {displayUser}!";
            
            await LoadUsers();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}