@page "/admin/buddysettlement"
@using BettingApp.Data
@using BettingApp.Services
@using System.Text.Json
@using System.Linq
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web
@attribute [Authorize]
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject SettlementService SettlementService
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject DiscordNotificationService DiscordService

<PageTitle>Buddy Settlement</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2>Buddy Settlement Snapshots</h2>
            <p class="text-muted small mb-0">
                <span class="bi bi-info-circle me-1"></span>
                Hint: Click on a day to expand its hourly snapshots, then click a snapshot to view settlement details.
            </p>
        </div>
        
        <button class="btn btn-warning" @onclick="ConfirmSnapshot">
            <span class="bi bi-camera-fill me-2"></span> Trigger Snapshot Now
        </button>
    </div>

    <div class="accordion mb-4" id="cashCowsAccordion">
        <div class="accordion-item shadow-sm border-0">
            <h2 class="accordion-header" id="headingCashCows">
                <button class="accordion-button collapsed bg-light text-primary fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCashCows" aria-expanded="false" aria-controls="collapseCashCows">
                    <i class="bi bi-wallet2 me-2"></i> Cash Cows Management
                </button>
            </h2>
            <div id="collapseCashCows" class="accordion-collapse collapse" aria-labelledby="headingCashCows" data-bs-parent="#cashCowsAccordion">
                <div class="accordion-body">
                    <div class="row g-3 align-items-end mb-3">
                        <div class="col-md-3">
                            <label class="form-label small text-muted fw-bold">First Name</label>
                            <input type="text" class="form-control" @bind="newCow.FirstName" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small text-muted fw-bold">Last Name</label>
                            <input type="text" class="form-control" @bind="newCow.LastName" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small text-muted fw-bold">Vipps</label>
                            <input type="text" class="form-control" @bind="newCow.Vipps" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label small text-muted fw-bold">Revolut</label>
                            <input type="text" class="form-control" @bind="newCow.Revolut" />
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-success w-100" @onclick="AddCashCow">Add Cash Cow</button>
                        </div>
                    </div>
                    @if (cashCows.Any())
                    {
                        <ul class="list-group">
                            @foreach (var cow in cashCows)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <strong>@cow.FirstName @cow.LastName</strong>
                                        <span class="text-muted ms-2 small">Vipps: @cow.Vipps | Revolut: @cow.Revolut</span>
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveCashCow(cow.Id)"><i class="bi bi-trash"></i></button>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (showConfirmation)
    {
        <div class="alert alert-warning border-warning shadow-sm">
            <h4><span class="bi bi-exclamation-triangle-fill text-danger me-2"></span>Confirm Snapshot</h4>
            <p>
                Are you sure you want to trigger a settlement snapshot right now?
                This will calculate who owes whom based on current balances.
            </p>
            @if (candidates.Any())
            {
                <div class="mb-3 p-3 bg-white rounded border border-warning shadow-sm">
                    <h5>Exclude Users</h5>
                    <p class="small text-muted mb-2">Select users to exclude from peer-to-peer matching. (They will be settled by the admin/castle instead):</p>
                    <div class="d-flex flex-wrap gap-3">
                        @foreach (var c in candidates)
                        {
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="excl_@c.UserName" 
                                       checked="@excludedUsers.Contains(c.UserName)"
                                       @onchange="@((ChangeEventArgs e) => ToggleExclude(c.UserName, e.Value))" />
                                <label class="form-check-label" for="excl_@c.UserName">
                                    @c.DisplayName
                                </label>
                            </div>
                        }
                    </div>
                </div>
            }
            <div class="d-flex gap-2">
                <button class="btn btn-danger" @onclick="ExecuteSnapshot">Yes, Execute</button>
                <button class="btn btn-secondary" @onclick="() => showConfirmation = false">Cancel</button>
            </div>
        </div>
    }

    @if (isLoading)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Norway Time</th>
                        <th>Local Time (Browser)</th>
                        <th>Trans.</th>
                        <th>Users</th>
                        <th>Volume</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (groupedSnapshots != null && groupedSnapshots.Any())
                    {
                        @foreach (var dayGroup in groupedSnapshots)
                        {
                            var isDayExpanded = expandedDays.Contains(dayGroup.Key);
                            
                            // Day Header Row (Grouped by Norway Date)
                            <tr class="table-secondary" @onclick="() => ToggleDay(dayGroup.Key)" style="cursor: pointer;">
                                <td colspan="2">
                                    <span class="bi @(isDayExpanded ? "bi-chevron-down" : "bi-chevron-right") me-2"></span>
                                    <strong>@dayGroup.Key.ToString("yyyy-MM-dd") (Norway)</strong>
                                </td>
                                <td><strong>@dayGroup.Sum(s => s.TransactionCount)</strong></td>
                                <td>-</td>
                                <td><strong>@dayGroup.Sum(s => s.TotalVolume).ToString("N0") kr</strong></td>
                                <td>
                                    <span class="badge bg-secondary">@(dayGroup.Count()) snapshots</span>
                                </td>
                            </tr>

                            // Hourly Snapshots (Expanded)
                            @if (isDayExpanded)
                            {
                                @foreach (var snap in dayGroup)
                                {
                                    var isExpanded = expandedRows.Contains(snap.Id);
                                    
                                    <tr @onclick="() => ToggleRow(snap.Id)" style="cursor: pointer;" class="@(isExpanded ? "table-active" : "")">
                                        <td class="ps-4 fw-bold">
                                            @TimeHelpers.GetNorwayTime(snap.CreatedAt).ToString("HH:mm")
                                        </td>
                                        <td>
                                            <span class="text-muted small">
                                                @ToUserLocal(snap.CreatedAt).ToString("yyyy-MM-dd HH:mm") Local
                                            </span>
                                        </td>
                                        <td>@snap.TransactionCount</td>
                                        <td>@snap.UserCount</td>
                                        <td>@snap.TotalVolume.ToString("N0") kr</td>
                                        <td @onclick:stopPropagation="true">
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => DownloadCsv(snap)">
                                                <span class="bi bi-download me-1"></span> CSV
                                            </button>
                                        </td>
                                    </tr>

                                    // Snapshot Details (Expanded)
                                    @if (isExpanded)
                                    {
                                        var details = GetSettlementDetails(snap);
                                        <tr>
                                            <td colspan="6" class="bg-light p-3 border-bottom">
                                                <div class="card shadow-sm">
                                                    <div class="card-header text-primary fw-bold">
                                                        Snapshot Details
                                                    </div>
                                                    <div class="card-body p-0">
                                                        @if (details != null)
                                                        {
                                                            // Historical Balances Display
                                                            <div class="p-3 bg-light border-bottom">
                                                                <h6 class="text-secondary mb-2">Balances at time of snapshot</h6>
                                                                @if (details.UserBalances != null && details.UserBalances.Any())
                                                                {
                                                                    <div class="d-flex flex-wrap gap-2">
                                                                        @foreach (var u in details.UserBalances)
                                                                        {
                                                                            var badgeClass = u.Balance > 0 ? "bg-success" : "bg-danger";
                                                                            <div class="badge @badgeClass text-white fs-6 p-2 shadow-sm">
                                                                                <span class="fw-normal me-1">@u.UserName:</span>
                                                                                <strong>@u.Balance.ToString("N0") kr</strong>
                                                                            </div>
                                                                        }
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <p class="text-muted small mb-0">No historical balances recorded for this snapshot.</p>
                                                                }
                                                            </div>

                                                            <div class="p-3">
                                                                <h6 class="text-secondary mb-3">Settlement Messages</h6>
                                                                @if (snapshotDebtorRows.TryGetValue(snap.Id, out var debtorRows) && debtorRows.Any())
                                                                {
                                                                    <div class="table-responsive">
                                                                        <table class="table table-bordered bg-white align-middle">
                                                                            <thead class="table-light">
                                                                                <tr>
                                                                                    <th style="width: 15%">Debtor</th>
                                                                                    <th style="width: 35%">Destinations & Payment Info</th>
                                                                                    <th style="width: 30%">Final Text (Editable)</th>
                                                                                    <th style="width: 20%">Discord Channel & Actions</th>
                                                                                </tr>
                                                                            </thead>
                                                                            <tbody>
                                                                                @foreach (var row in debtorRows)
                                                                                {
                                                                                    <tr class="@(row.IsCancelled ? "opacity-50 bg-light" : "")">
                                                                                        <td>
                                                                                            <strong>@row.UserName</strong><br/>
                                                                                            <span class="text-danger fw-bold">-@row.TotalAmount.ToString("N0") kr</span>
                                                                                            @if (row.IsSent)
                                                                                            {
                                                                                                <div class="mt-2 badge bg-success"><i class="bi bi-check-circle-fill"></i> Sent via Discord</div>
                                                                                            }
                                                                                            @if (row.IsCancelled)
                                                                                            {
                                                                                                <div class="mt-2 badge bg-secondary"><i class="bi bi-slash-circle"></i> Cancelled</div>
                                                                                            }
                                                                                        </td>
                                                                                        <td>
                                                                                            @foreach (var dest in row.Destinations)
                                                                                            {
                                                                                                <div class="mb-2 p-2 border rounded bg-light">
                                                                                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                                        <div>
                                                                                                            <strong>To: @dest.ToName</strong> <span class="badge bg-secondary ms-2">@dest.Amount.ToString("N0") kr</span>
                                                                                                        </div>
                                                                                                        @if (dest.IsCastle)
                                                                                                        {
                                                                                                            <select class="form-select form-select-sm w-50" value="@dest.SelectedCowId" @onchange="@((ChangeEventArgs e) => OnCowSelected(dest, row, e.Value?.ToString()))">
                                                                                                                <option value="">-- Select Cash Cow --</option>
                                                                                                                @foreach(var cow in cashCows)
                                                                                                                {
                                                                                                                    <option value="@cow.Id">@cow.FirstName @cow.LastName</option>
                                                                                                                }
                                                                                                            </select>
                                                                                                        }
                                                                                                    </div>
                                                                                                    <div class="mt-2">
                                                                                                        <div class="input-group input-group-sm mb-1">
                                                                                                            <span class="input-group-text" style="width: 70px;">Vipps</span>
                                                                                                            <input type="text" class="form-control" @bind="dest.Vipps" @bind:event="oninput" @bind:after="() => row.GenerateText()" />
                                                                                                        </div>
                                                                                                        <div class="input-group input-group-sm">
                                                                                                            <span class="input-group-text" style="width: 70px;">Revolut</span>
                                                                                                            <input type="text" class="form-control" @bind="dest.Revolut" @bind:event="oninput" @bind:after="() => row.GenerateText()" />
                                                                                                        </div>
                                                                                                    </div>
                                                                                                </div>
                                                                                            }
                                                                                        </td>
                                                                                        <td>
                                                                                            <textarea class="form-control form-control-sm" rows="8" style="font-size: 0.8rem; resize: vertical;" @bind="row.FinalText" @bind:event="oninput"></textarea>
                                                                                        </td>
                                                                                        <td>
                                                                                            <label class="small text-muted fw-bold mb-1">Send to Discord</label>
                                                                                            <select class="form-select form-select-sm mb-2" style="min-width: 200px;" @bind="row.SelectedChannelId">
                                                                                                <option value="0">-- Select Channel --</option>
                                                                                                @foreach(var ch in availableChannels)
                                                                                                {
                                                                                                    <option value="@ch.Id">#@ch.Name</option>
                                                                                                }
                                                                                            </select>
                                                                                            
                                                                                            <div class="d-flex gap-2">
                                                                                                <button class="btn btn-primary btn-sm w-100" disabled="@(row.IsSending || row.SelectedChannelId == 0 || row.IsCancelled)" @onclick="() => SendToDiscord(row, snap.Id)">
                                                                                                    @if (row.IsSending)
                                                                                                    {
                                                                                                        <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                                                                                                    }
                                                                                                    else
                                                                                                    {
                                                                                                        <i class="bi bi-send-fill me-1"></i>
                                                                                                        @(row.IsSent ? "Send Again" : "Send")
                                                                                                    }
                                                                                                </button>
                                                                                                
                                                                                                <button class="btn @(row.IsCancelled ? "btn-outline-secondary" : "btn-outline-danger") btn-sm" @onclick="() => ToggleCancel(row, snap.Id)" title="Cancel for this week">
                                                                                                    <i class="bi @(row.IsCancelled ? "bi-arrow-counterclockwise" : "bi-x-circle")"></i>
                                                                                                </button>
                                                                                            </div>
                                                                                            
                                                                                            @if (!string.IsNullOrEmpty(row.CopiedMessage))
                                                                                            {
                                                                                                <div class="text-success small fw-bold mt-2"><i class="bi bi-check-circle-fill"></i> @row.CopiedMessage</div>
                                                                                            }
                                                                                        </td>
                                                                                    </tr>
                                                                                }
                                                                            </tbody>
                                                                        </table>
                                                                    </div>
                                                                }
                                                                else
                                                                {
                                                                    <p class="text-muted small">No debtors to settle.</p>
                                                                }
                                                                
                                                                @{
                                                                    var adminPayouts = details.Adjustments.Where(a => a.Reason == "Castle Owes Directly").ToList();
                                                                    if (adminPayouts.Any())
                                                                    {
                                                                        <div class="mt-4 border-top pt-3">
                                                                            <h5 class="text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>Admin Payouts Required</h5>
                                                                            <p class="small text-muted">The peer-to-peer settlement could not cover these withdrawals. Castle needs to pay these directly from company funds.</p>
                                                                            <table class="table table-sm table-bordered mt-2">
                                                                                <thead class="table-danger">
                                                                                    <tr>
                                                                                        <th>User Owed</th>
                                                                                        <th>Amount to Pay</th>
                                                                                    </tr>
                                                                                </thead>
                                                                                <tbody>
                                                                                    @foreach (var payout in adminPayouts)
                                                                                    {
                                                                                        <tr>
                                                                                            <td><strong>@payout.UserName</strong></td>
                                                                                            <td class="text-danger fw-bold">@payout.Amount.ToString("N0") kr</td>
                                                                                        </tr>
                                                                                    }
                                                                                </tbody>
                                                                            </table>
                                                                        </div>
                                                                    }
                                                                }
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <div class="p-3 text-danger">Error loading details JSON.</div>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            }
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-4">No snapshots found. Trigger one to start!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        
        @if (totalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="text-muted small">Page @currentPage of @totalPages</span>
                <div>
                    <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage == 1)" @onclick="PrevPage">Previous</button>
                    <button class="btn btn-outline-secondary btn-sm ms-2" disabled="@(currentPage == totalPages)" @onclick="NextPage">Next</button>
                </div>
            </div>
        }
    }
</div>

<script>
    window.downloadFileFromStream = async (fileName, contentStreamReference) => {
        const arrayBuffer = await contentStreamReference.arrayBuffer();
        const blob = new Blob([arrayBuffer]);
        const url = URL.createObjectURL(blob);
        const anchorElement = document.createElement('a');
        anchorElement.href = url;
        anchorElement.download = fileName ?? '';
        anchorElement.click();
        anchorElement.remove();
        URL.revokeObjectURL(url);
    }
    window.copyTextToClipboard = async (text) => {
        try {
            await navigator.clipboard.writeText(text);
        } catch (err) {
            console.error('Failed to copy text: ', err);
        }
    }
</script>

@code {
    public class SettlementCandidate
    {
        public string UserName { get; set; } = "";
        public string DisplayName { get; set; } = "";
    }

    public class DebtorRow
    {
        public string UserName { get; set; } = "";
        public decimal TotalAmount { get; set; }
        public List<DebtorDestination> Destinations { get; set; } = new();
        public string CopiedMessage { get; set; } = "";
        public string FinalText { get; set; } = "";
        
        public ulong SelectedChannelId { get; set; }
        public bool IsSent { get; set; }
        public bool IsSending { get; set; }
        public bool IsCancelled { get; set; }
        
        public void GenerateText()
        {
            string amtStr = TotalAmount.ToString("N0").Replace(",", " ");
            var sb = new System.Text.StringBuilder();
            sb.AppendLine($"Hei! Saldoen din står i **-{amtStr} kr**");
            sb.AppendLine();
            sb.AppendLine("Fint om du kan gjøre opp dette via følgende løsninger:");
            
            foreach (var dest in Destinations)
            {
                sb.AppendLine($"👉 **Til {dest.ToName} ({dest.Amount.ToString("N0")} kr)**");
                
                var methods = new List<string>();
                if (!string.IsNullOrWhiteSpace(dest.Vipps)) methods.Add($"- **Vipps:** `{dest.Vipps.Trim()}`");
                if (!string.IsNullOrWhiteSpace(dest.Revolut)) methods.Add($"- **Revolut:** `{dest.Revolut.Trim()}`");
                
                if (methods.Any())
                {
                    sb.AppendLine(string.Join("\n", methods));
                }
                sb.AppendLine();
            }
            
            sb.AppendLine("📸 Vennligst send oss et skjermbilde av kvitteringen når det er gjort, så skal vi sørge for å oppdatere saldoen din så raskt som mulig.");
            sb.AppendLine();
            sb.AppendLine("Tusen takk! 🙏");
            
            FinalText = sb.ToString().TrimEnd();
        }
    }

    public class DebtorDestination
    {
        public string ToName { get; set; } = "";
        public decimal Amount { get; set; }
        public string Vipps { get; set; } = "";
        public string Revolut { get; set; } = "";
        public bool IsCastle { get; set; } = false;
        public string SelectedCowId { get; set; } = "";
    }

    private List<SettlementSnapshot> snapshots = new();
    private List<IGrouping<DateTime, SettlementSnapshot>> groupedSnapshots = new();
    private HashSet<int> expandedRows = new();
    private HashSet<DateTime> expandedDays = new();
    private Dictionary<int, List<DebtorRow>> snapshotDebtorRows = new();
    private List<SettlementCandidate> candidates = new();
    private HashSet<string> excludedUsers = new();
    
    private List<CashCow> cashCows = new();
    private CashCow newCow = new();
    
    private List<(ulong Id, string Name)> availableChannels = new();
    
    private bool isLoading = true;
    private bool showConfirmation = false;
    
    // Pagination
    private int currentPage = 1;
    private int pageSize = 120; // 5 days worth of hourly snapshots
    private int totalPages = 1;
    
    // Browser local time logic
    private int TimezoneOffset { get; set; }

    private DateTime ToUserLocal(DateTime utcDate)
    {
        if (utcDate == DateTime.MinValue || utcDate == DateTime.MaxValue) return utcDate;
        return utcDate.AddMinutes(-TimezoneOffset);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        using var context = DbFactory.CreateDbContext();
        
        var currentUserName = user.Identity?.Name;
        var dbUser = await context.Users.AsNoTracking().FirstOrDefaultAsync(u => u.UserName == currentUserName);
        if (dbUser?.IsAdmin != true)
        {
            NavigationManager.NavigateTo("Account/Login");
            return;
        }

        var setting = await context.Settings.OrderBy(s => s.Id).FirstOrDefaultAsync();
        if (setting != null && !string.IsNullOrEmpty(setting.CashCowsJson))
        {
            try {
                cashCows = JsonSerializer.Deserialize<List<CashCow>>(setting.CashCowsJson) ?? new();
            } catch { }
        }

        availableChannels = await DiscordService.GetGuildTextChannelsAsync();

        await LoadSnapshots();
    }

    private async Task AddCashCow()
    {
        if (string.IsNullOrWhiteSpace(newCow.FirstName)) return;
        cashCows.Add(newCow);
        newCow = new CashCow();
        await SaveCashCows();
    }

    private async Task RemoveCashCow(string id)
    {
        cashCows.RemoveAll(c => c.Id == id);
        await SaveCashCows();
    }

    private async Task SaveCashCows()
    {
        using var context = DbFactory.CreateDbContext();
        var setting = await context.Settings.OrderBy(s => s.Id).FirstOrDefaultAsync();
        if (setting == null)
        {
            setting = new SystemSetting();
            context.Settings.Add(setting);
        }
        setting.CashCowsJson = JsonSerializer.Serialize(cashCows);
        await context.SaveChangesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try 
            {
                TimezoneOffset = await JS.InvokeAsync<int>("getBrowserTimeZoneOffset");
                StateHasChanged();
            }
            catch { /* Ignore JS errors */ }
        }
    }

    private async Task LoadSnapshots()
    {
        isLoading = true;
        using var context = DbFactory.CreateDbContext();
        
        // Load Snapshots
        int totalCount = await context.SettlementSnapshots.CountAsync();
        totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
        if (totalPages < 1) totalPages = 1;

        snapshots = await context.SettlementSnapshots
            .OrderByDescending(s => s.CreatedAt)
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync();
            
        // Group the fetched snapshots by Norway Date using TimeHelpers
        groupedSnapshots = snapshots
            .GroupBy(s => TimeHelpers.GetNorwayTime(s.CreatedAt).Date)
            .ToList();
            
        // Optional: Auto-expand the most recent day
        if (groupedSnapshots.Any() && !expandedDays.Any())
        {
            expandedDays.Add(groupedSnapshots.First().Key);
        }

        isLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadSnapshots();
        }
    }

    private async Task PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadSnapshots();
        }
    }

    private async Task ConfirmSnapshot()
    {
        using var context = DbFactory.CreateDbContext();
        
        var debtorsQuery = await context.Users
            .Where(u => u.Balance < 0 && !u.IsAdmin && !u.IsTestUser)
            .Select(u => new { u.UserName, u.DiscordUsername, u.LastName })
            .ToListAsync();
            
        var allUserNames = debtorsQuery.Select(u => u.UserName).Distinct().ToList();
        
        var userLookup = debtorsQuery.ToDictionary(u => u.UserName!, u => u);

        candidates = allUserNames.Where(n => !string.IsNullOrEmpty(n)).Select(userName => {
            var u = userLookup[userName!];
            string displayName = string.IsNullOrWhiteSpace(u.DiscordUsername) ? u.UserName! : $"{u.DiscordUsername} ({u.LastName})";
            return new SettlementCandidate
            {
                UserName = u.UserName!,
                DisplayName = displayName
            };
        }).OrderBy(c => c.DisplayName).ToList();

        excludedUsers.Clear();
        showConfirmation = true;
    }

    private void ToggleExclude(string userName, object? isChecked)
    {
        if (isChecked is bool b && b)
            excludedUsers.Add(userName);
        else
            excludedUsers.Remove(userName);
    }

    private async Task ExecuteSnapshot()
    {
        showConfirmation = false;
        isLoading = true;
        await Task.Delay(50);
        await SettlementService.CreateSnapshotAsync(excludedUsers.ToList());
        
        // Reset to page 1 to see the new snapshot
        currentPage = 1;
        await LoadSnapshots(); 
    }

    private void ToggleDay(DateTime date)
    {
        if (expandedDays.Contains(date))
            expandedDays.Remove(date);
        else
            expandedDays.Add(date);
    }

    private void ToggleRow(int id)
    {
        if (expandedRows.Contains(id))
            expandedRows.Remove(id);
        else
        {
            expandedRows.Add(id);
            if (!snapshotDebtorRows.ContainsKey(id))
            {
                var snap = snapshots.FirstOrDefault(s => s.Id == id);
                if (snap != null)
                {
                    var details = GetSettlementDetails(snap);
                    if (details != null)
                    {
                        snapshotDebtorRows[id] = BuildDebtorRows(details);
                    }
                }
            }
        }
    }

    private List<DebtorRow> BuildDebtorRows(SettlementResult details)
    {
        var dict = new Dictionary<string, DebtorRow>();
        
        foreach (var ins in details.Instructions)
        {
            if (!dict.ContainsKey(ins.FromUser)) 
            {
                dict[ins.FromUser] = new DebtorRow 
                { 
                    UserName = ins.FromUser,
                    IsSent = ins.IsSent,
                    IsCancelled = ins.IsCancelled
                };
            }
            
            // Use ToUserFirstName if available, otherwise fallback to the first part of the original display name
            string toName = !string.IsNullOrEmpty(ins.ToUserFirstName) ? ins.ToUserFirstName : ins.ToUser.Split(' ')[0];
            var dest = new DebtorDestination { ToName = toName, Amount = ins.Amount };
            
            if (!string.IsNullOrEmpty(ins.PaymentDetails))
            {
                var parts = ins.PaymentDetails.Split(new[] { " / ", " | " }, StringSplitOptions.RemoveEmptyEntries);
                foreach (var part in parts)
                {
                    if (part.Trim().StartsWith("Vipps:", StringComparison.OrdinalIgnoreCase))
                        dest.Vipps = part.Replace("Vipps:", "", StringComparison.OrdinalIgnoreCase).Trim();
                    else if (part.Trim().StartsWith("Revolut:", StringComparison.OrdinalIgnoreCase))
                        dest.Revolut = part.Replace("Revolut:", "", StringComparison.OrdinalIgnoreCase).Trim();
                }
                if (string.IsNullOrEmpty(dest.Vipps) && string.IsNullOrEmpty(dest.Revolut)) dest.Vipps = ins.PaymentDetails;
            }
            dict[ins.FromUser].Destinations.Add(dest);
        }
        
        foreach (var adj in details.Adjustments.Where(a => a.Reason == "Owes Castle Directly"))
        {
            if (!dict.ContainsKey(adj.UserName)) 
            {
                dict[adj.UserName] = new DebtorRow 
                { 
                    UserName = adj.UserName,
                    IsSent = adj.IsSent,
                    IsCancelled = adj.IsCancelled
                };
            }
            var dest = new DebtorDestination 
            { 
                ToName = "Velg Cash Cow", 
                Amount = adj.Amount,
                IsCastle = true
            };
            
            if (details.SelectedCashCows != null && details.SelectedCashCows.TryGetValue(adj.UserName, out var cowId))
            {
                dest.SelectedCowId = cowId;
                var cow = cashCows.FirstOrDefault(c => c.Id == cowId);
                if (cow != null)
                {
                    dest.ToName = cow.FirstName;
                    dest.Vipps = cow.Vipps;
                    dest.Revolut = cow.Revolut;
                }
            }
            
            dict[adj.UserName].Destinations.Add(dest);
        }
        
        var rows = dict.Values.OrderByDescending(r => r.Destinations.Sum(d => d.Amount)).ToList();
        foreach (var row in rows)
        {
            row.TotalAmount = row.Destinations.Sum(d => d.Amount);
            row.GenerateText();
            
            if (details.FinalTexts != null && details.FinalTexts.TryGetValue(row.UserName, out var savedText))
            {
                row.FinalText = savedText;
            }
            
            // Auto-select Discord channel based on username (more robust matching)
            string rawDiscordName = row.UserName.Split('(')[0].Trim().ToLower();
            string cleanName = rawDiscordName.Replace(" ", "").Replace("-", "").Replace("_", "");
            
            var matchedChannel = availableChannels.FirstOrDefault(c => 
                c.Name.ToLower().Replace("-", "").Replace("_", "").Replace(" ", "") == $"{cleanName}admins" ||
                c.Name.ToLower().Replace("-", "").Replace("_", "").Replace(" ", "") == $"{cleanName}admin"
            );
            
            if (matchedChannel.Id != 0)
            {
                row.SelectedChannelId = matchedChannel.Id;
            }
        }
        return rows;
    }

    private void OnCowSelected(DebtorDestination dest, DebtorRow row, string? cowId)
    {
        dest.SelectedCowId = cowId ?? "";
        var cow = cashCows.FirstOrDefault(c => c.Id == cowId);
        if (cow != null)
        {
            dest.ToName = cow.FirstName;
            dest.Vipps = cow.Vipps;
            dest.Revolut = cow.Revolut;
        }
        else
        {
            dest.ToName = "Velg Cash Cow";
            dest.Vipps = "";
            dest.Revolut = "";
        }
        row.GenerateText();
    }

    private SettlementResult? GetSettlementDetails(SettlementSnapshot snap)
    {
        try
        {
            var json = snap.SettlementJson ?? "{}";
            return JsonSerializer.Deserialize<SettlementResult>(json);
        }
        catch
        {
            return null;
        }
    }

    private async Task DownloadCsv(SettlementSnapshot snap)
    {
        var json = snap.SettlementJson ?? "{}";
        var result = JsonSerializer.Deserialize<SettlementResult>(json);
        
        if (result == null) return;
        
        var csvContent = SettlementService.GenerateCsv(result, snap.CreatedAt);
        var fileBytes = System.Text.Encoding.UTF8.GetBytes(csvContent);
        using var stream = new MemoryStream(fileBytes);
        using var streamRef = new DotNetStreamReference(stream);

        var norwayTime = TimeHelpers.GetNorwayTime(snap.CreatedAt);
        var fileName = $"Settlement_{norwayTime:yyyyMMdd_HHmm}.csv";
        await JS.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
    }

    private async Task SendToDiscord(DebtorRow row, int snapshotId)
    {
        if (row.SelectedChannelId == 0) return;
        
        row.IsSending = true;
        StateHasChanged();

        var successCount = await DiscordService.BroadcastMessageAsync(
            new List<ulong> { row.SelectedChannelId },
            "", // No title needed, we just want the message directly
            row.FinalText
        );

        row.IsSending = false;

        if (successCount > 0)
        {
            row.IsSent = true;
            row.CopiedMessage = "Sent!";
            
            // Now we need to save the IsSent flag back into the DB snapshot
            using var context = DbFactory.CreateDbContext();
            var snap = await context.SettlementSnapshots.FindAsync(snapshotId);
            if (snap != null)
            {
                var details = GetSettlementDetails(snap);
                if (details != null)
                {
                    // Mark matching instructions
                    foreach (var ins in details.Instructions.Where(i => i.FromUser == row.UserName))
                    {
                        ins.IsSent = true;
                    }
                    // Mark matching adjustments
                    foreach (var adj in details.Adjustments.Where(a => a.UserName == row.UserName && a.Reason == "Owes Castle Directly"))
                    {
                        adj.IsSent = true;
                    }
                    
                    if (details.FinalTexts == null) details.FinalTexts = new();
                    if (details.SelectedCashCows == null) details.SelectedCashCows = new();
                    
                    details.FinalTexts[row.UserName] = row.FinalText;
                    
                    foreach (var dest in row.Destinations.Where(d => d.IsCastle && !string.IsNullOrEmpty(d.SelectedCowId)))
                    {
                        details.SelectedCashCows[row.UserName] = dest.SelectedCowId;
                    }
                    
                    snap.SettlementJson = JsonSerializer.Serialize(details);
                    await context.SaveChangesAsync();
                    
                    // Update our in-memory list
                    var index = snapshots.FindIndex(s => s.Id == snap.Id);
                    if (index != -1) snapshots[index] = snap;
                }
            }
        }
        else
        {
            row.CopiedMessage = "Failed!";
        }
        
        StateHasChanged();
        await Task.Delay(3000);
        row.CopiedMessage = "";
        StateHasChanged();
    }

    private async Task ToggleCancel(DebtorRow row, int snapshotId)
    {
        row.IsCancelled = !row.IsCancelled;
        
        using var context = DbFactory.CreateDbContext();
        var snap = await context.SettlementSnapshots.FindAsync(snapshotId);
        if (snap != null)
        {
            var details = GetSettlementDetails(snap);
            if (details != null)
            {
                foreach (var ins in details.Instructions.Where(i => i.FromUser == row.UserName))
                {
                    ins.IsCancelled = row.IsCancelled;
                }
                foreach (var adj in details.Adjustments.Where(a => a.UserName == row.UserName && a.Reason == "Owes Castle Directly"))
                {
                    adj.IsCancelled = row.IsCancelled;
                }
                
                snap.SettlementJson = JsonSerializer.Serialize(details);
                await context.SaveChangesAsync();
                
                var index = snapshots.FindIndex(s => s.Id == snap.Id);
                if (index != -1) snapshots[index] = snap;
            }
        }
        StateHasChanged();
    }
}